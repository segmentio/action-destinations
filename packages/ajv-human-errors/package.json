{
  "name": "@segment/ajv-human-errors",
  "version": "2.16.0",
  "description": "Human-readable error messages for Ajv (Another JSON Schema Validator).",
  "repository": {
    "type": "git",
    "url": "https://github.com/segmentio/action-destinations",
    "directory": "packages/ajv-human-errors"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "prepack": "yarn build",
    "prebuild": "yarn clean",
    "build": "yarn clean && yarn build:cjs && yarn build:esm && yarn build:types",
    "build:cjs": "swc src -d dist/cjs --config-file ../../.swcrc.cjs --strip-leading-paths",
    "build:esm": "swc src -d dist/esm --config-file ../../.swcrc.esm --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly && tsc -b tsconfig.build.json && cp -r dist/esm/*.d.ts* dist/cjs/ 2>/dev/null || true",
    "clean": "tsc --build tsconfig.build.json --clean",
    "postclean": "rm -rf dist",
    "prepublishOnly": "yarn build",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "jest": "^27.3.1"
  },
  "peerDependencies": {
    "ajv": "^8.0.0"
  }
}
