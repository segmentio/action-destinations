  "presets": [
    {
      "name": "App Install",
      "type": "automatic",
      "partnerAction": "trackConversion",
      "subscribe": "type = \"track\" and event = \"Application Installed\"",
      "mapping": {
        "event_name": "AppInstall",
        "segment_event_name": {
          "@path": "$.event"
        },
        "timestamp": {
          "@path": "$.timestamp"
        },
        "click_id": {
          "@if": {
            "exists": {
              "@path": "$.properties.qclid"
            },
            "then": {
              "@path": "$.properties.qclid"
            },
            "else": {
              "@path": "$.context.qclid"
