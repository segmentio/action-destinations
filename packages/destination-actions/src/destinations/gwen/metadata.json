  ],
  "presets": [
    {
      "partnerAction": "identifyUser",
      "name": "Identify a user",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "userId": {
          "@path": "$.userId"
        },
        "ip": {
          "@path": "$.context.ip"
        },
        "userAgent": {
          "@path": "$.context.userAgent"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "sendEvent",
      "name": "Send an event to GWEN",
      "subscribe": "type = \"track\"",
      "mapping": {
        "userId": {
          "@path": "$.userId"
        },
        "type": {
          "@path": "$.type"
        },
        "data": {
          "@path": "$.properties"
        }
      },
      "type": "automatic"
    }
