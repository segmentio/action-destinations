{
  "name": "Posthog",
  "description": "Send events server-side to the [Posthog REST API](https://posthog.com/docs/api).",
  "basicOptions": [
    "api_key",
    "project_id",
    "endpoint",
    "historical_migration",
    "geoip_disable"
  ],
  "options": {
    "api_key": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Found in your project settings, under \"Project API key\"",
      "encrypt": true,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The api_key property is required."
        ]
      ],
      "uIMetadata": null
    },
    "project_id": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Found in your project settings, under \"Project ID\"",
      "encrypt": false,
      "hidden": false,
      "label": "Project ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The project_id property is required."
        ]
      ],
      "uIMetadata": null
    },
    "endpoint": {
      "tags": [
        "authentication:test"
      ],
      "default": "https://us.i.posthog.com",
      "description": "API Endpoint URL based on project region",
      "encrypt": false,
      "hidden": false,
      "label": "Project Region",
      "private": true,
      "scope": "event_destination",
      "type": "select",
      "options": [
        {
          "value": "https://us.i.posthog.com",
          "label": "US Cloud (https://us.i.posthog.com)",
          "text": "US Cloud (https://us.i.posthog.com)"
        },
        {
          "value": "https://eu.i.posthog.com",
          "label": "EU Cloud (https://eu.i.posthog.com)",
          "text": "EU Cloud (https://eu.i.posthog.com)"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The endpoint property is required."
        ]
      ],
      "uIMetadata": null
    },
    "historical_migration": {
      "tags": [
        "authentication:test"
      ],
      "default": false,
      "description": "If enabled, this ensures that events are processed in order without triggering our spike detection systems. Affects events sent via the track Action only.",
      "encrypt": false,
      "hidden": false,
      "label": "Historical Migration",
      "private": true,
      "scope": "event_destination",
      "type": "boolean",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "geoip_disable": {
      "tags": [
        "authentication:test"
      ],
      "default": false,
      "description": "If enabled, [GeoIP collection](https://github.com/PostHog/posthog-plugin-geoip) will be disabled. This will prevent the collection of IP addresses and other geolocation data.",
      "encrypt": false,
      "hidden": false,
      "label": "Disable GeoIP Collection",
      "private": true,
      "scope": "event_destination",
      "type": "boolean",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "identify",
      "name": "Identify",
      "description": "Updates person properties. Read more in our [identify docs](https://posthog.com/docs/product-analytics/identify).",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": null,
      "fields": [
        {
          "fieldKey": "distinct_id",
          "type": "string",
          "label": "Distinct ID",
          "description": "The distinct ID of the user",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "distinct_id": {
                "title": "Distinct ID",
                "description": "The distinct ID of the user",
                "type": "string"
              }
            },
            "required": [
              "distinct_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "properties",
          "type": "object",
          "label": "Properties",
          "description": "The properties of the user",
          "defaultValue": {
            "@path": "$.traits"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "properties": {
                "title": "Properties",
                "description": "The properties of the user",
                "type": "object"
              }
            },
            "required": [
              "properties"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "timestamp",
          "type": "datetime",
          "label": "Timestamp",
          "description": "The timestamp of the event",
          "defaultValue": {
            "@path": "$.timestamp"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "timestamp": {
                "title": "Timestamp",
                "description": "The timestamp of the event",
                "type": [
                  "string",
                  "number"
                ],
                "format": "date-like"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "ip_address",
          "type": "string",
          "label": "IP Address",
          "description": "The IP address of the user",
          "defaultValue": {
            "@path": "$.context.ip"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ip_address": {
                "title": "IP Address",
                "description": "The IP address of the user",
                "type": [
                  "string",
                  "null"
                ],
                "format": "ipv4"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    },
    {
      "slug": "event",
      "name": "Track Event",
      "description": "Track a single event in Posthog. Every event request must contain an `api_key`, `distinct_id`, and `event` field with the name. Both the `properties` and `timestamp` fields are optional.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\"",
      "fields": [
        {
          "fieldKey": "event_type",
          "type": "string",
          "label": "Event Type",
          "description": "For regular analytics events, use `track`. For page views, use `page`. For mobile screens, use `screen`.",
          "defaultValue": "track",
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "track",
              "value": "track"
            },
            {
              "label": "page",
              "value": "page"
            },
            {
              "label": "screen",
              "value": "screen"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "event_type": {
                "title": "Event Type",
                "description": "For regular analytics events, use `track`. For page views, use `page`. For mobile screens, use `screen`.",
                "type": "string",
                "enum": [
                  "track",
                  "page",
                  "screen"
                ]
              }
            },
            "required": [
              "event_type"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "event_name",
          "type": "string",
          "label": "Event Name",
          "description": "The name of the event to track",
          "defaultValue": {
            "@path": "$.event"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "event_name": {
                "title": "Event Name",
                "description": "The name of the event to track",
                "type": "string"
              }
            },
            "required": [
              "event_name"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "distinct_id",
          "type": "string",
          "label": "Distinct ID",
          "description": "The distinct ID of the user",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "distinct_id": {
                "title": "Distinct ID",
                "description": "The distinct ID of the user",
                "type": "string"
              }
            },
            "required": [
              "distinct_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "properties",
          "type": "object",
          "label": "Properties",
          "description": "The properties of the event",
          "defaultValue": {
            "@path": "$.properties"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "properties": {
                "title": "Properties",
                "description": "The properties of the event",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "current_url",
          "type": "string",
          "label": "Current URL",
          "description": "The current URL of the page being viewed. Only required for page events.",
          "defaultValue": {
            "@path": "$.context.page.url"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "current_url": {
                "title": "Current URL",
                "description": "The current URL of the page being viewed. Only required for page events.",
                "type": "string"
              }
            },
            "required": [],
            "allOf": [
              {
                "if": {
                  "required": [
                    "event_type"
                  ],
                  "properties": {
                    "event_type": {
                      "const": "page"
                    }
                  }
                },
                "then": {
                  "required": [
                    "current_url"
                  ]
                }
              }
            ]
          },
          "dependsOn": {
            "conditions": [
              {
                "fieldKey": "event_type",
                "operator": "is",
                "value": "page"
              }
            ]
          },
          "displayMetadata": {
            "conditionallyRequired": {
              "conditions": [
                {
                  "fieldKey": "event_type",
                  "operator": "is",
                  "value": "page"
                }
              ]
            }
          }
        },
        {
          "fieldKey": "screen_name",
          "type": "string",
          "label": "Screen Name",
          "description": "The name of the mobile screen being viewed. Only required for screen events.",
          "defaultValue": {
            "@path": "$.name"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "screen_name": {
                "title": "Screen Name",
                "description": "The name of the mobile screen being viewed. Only required for screen events.",
                "type": "string"
              }
            },
            "required": [],
            "allOf": [
              {
                "if": {
                  "required": [
                    "event_type"
                  ],
                  "properties": {
                    "event_type": {
                      "const": "screen"
                    }
                  }
                },
                "then": {
                  "required": [
                    "screen_name"
                  ]
                }
              }
            ]
          },
          "dependsOn": {
            "conditions": [
              {
                "fieldKey": "event_type",
                "operator": "is",
                "value": "screen"
              }
            ]
          },
          "displayMetadata": {
            "conditionallyRequired": {
              "conditions": [
                {
                  "fieldKey": "event_type",
                  "operator": "is",
                  "value": "screen"
                }
              ]
            }
          }
        },
        {
          "fieldKey": "anonymous_event_capture",
          "type": "boolean",
          "label": "Anonymous Event Capture",
          "description": "To capture this event as an [anonymous event](https://posthog.com/docs/data/anonymous-vs-identified-events), set this field to `true`",
          "defaultValue": false,
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "anonymous_event_capture": {
                "title": "Anonymous Event Capture",
                "description": "To capture this event as an [anonymous event](https://posthog.com/docs/data/anonymous-vs-identified-events), set this field to `true`",
                "type": "boolean"
              }
            },
            "required": [
              "anonymous_event_capture"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "timestamp",
          "type": "datetime",
          "label": "Timestamp",
          "description": "The timestamp of the event",
          "defaultValue": {
            "@path": "$.receivedAt"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "timestamp": {
                "title": "Timestamp",
                "description": "The timestamp of the event",
                "type": [
                  "string",
                  "number"
                ],
                "format": "date-like"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Enable Batching",
          "description": "If enabled, event may be batched and send in bulk to Posthog.",
          "defaultValue": false,
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enable_batching": {
                "title": "Enable Batching",
                "description": "If enabled, event may be batched and send in bulk to Posthog.",
                "type": "boolean"
              }
            },
            "required": [
              "enable_batching"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "batch_size",
          "type": "number",
          "label": "Batch Size",
          "description": "Maximum number of events to include in each batch. Actual batch sizes may be lower.",
          "defaultValue": 100,
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batch_size": {
                "title": "Batch Size",
                "description": "Maximum number of events to include in each batch. Actual batch sizes may be lower.",
                "type": "number"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "ip_address",
          "type": "string",
          "label": "IP Address",
          "description": "The IP address of the user",
          "defaultValue": {
            "@path": "$.context.ip"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ip_address": {
                "title": "IP Address",
                "description": "The IP address of the user",
                "type": [
                  "string",
                  "null"
                ],
                "format": "ipv4"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": [
    {
      "partnerAction": "identify",
      "name": "Identify",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "distinct_id": {
          "@path": "$.userId"
        },
        "properties": {
          "@path": "$.traits"
        },
        "timestamp": {
          "@path": "$.timestamp"
        },
        "ip_address": {
          "@path": "$.context.ip"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "event",
      "name": "Page View",
      "subscribe": "type = \"page\"",
      "mapping": {
        "event_type": "page",
        "event_name": "$pageview",
        "distinct_id": {
          "@path": "$.userId"
        },
        "properties": {
          "@path": "$.properties"
        },
        "current_url": {
          "@path": "$.context.page.url"
        },
        "screen_name": {
          "@path": "$.name"
        },
        "anonymous_event_capture": false,
        "timestamp": {
          "@path": "$.receivedAt"
        },
        "enable_batching": false,
        "batch_size": 100,
        "ip_address": {
          "@path": "$.context.ip"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "event",
      "name": "Screen View",
      "subscribe": "type = \"screen\"",
      "mapping": {
        "event_type": "screen",
        "event_name": "$screenview",
        "distinct_id": {
          "@path": "$.userId"
        },
        "properties": {
          "@path": "$.properties"
        },
        "current_url": {
          "@path": "$.context.page.url"
        },
        "screen_name": {
          "@path": "$.name"
        },
        "anonymous_event_capture": false,
        "timestamp": {
          "@path": "$.receivedAt"
        },
        "enable_batching": false,
        "batch_size": 100,
        "ip_address": {
          "@path": "$.context.ip"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "event",
      "name": "Track Event",
      "subscribe": "type = \"track\"",
      "mapping": {
        "event_type": "track",
        "event_name": {
          "@path": "$.event"
        },
        "distinct_id": {
          "@path": "$.userId"
        },
        "properties": {
          "@path": "$.properties"
        },
        "current_url": {
          "@path": "$.context.page.url"
        },
        "screen_name": {
          "@path": "$.name"
        },
        "anonymous_event_capture": false,
        "timestamp": {
          "@path": "$.receivedAt"
        },
        "enable_batching": false,
        "batch_size": 100,
        "ip_address": {
          "@path": "$.context.ip"
        }
      },
      "type": "automatic"
    }
  ]
}
