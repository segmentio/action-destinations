      "hasPerformBatch": true,
      "syncMode": null,
      "hooks": null,
      "fields": {
        "event_type": {
          "label": "Event Type",
          "description": "For regular analytics events, use `track`. For page views, use `page`. For mobile screens, use `screen`.",
          "type": "string",
          "required": true,
          "multiple": false,
          "allowNull": false,
          "dynamic": false,
          "default": "track",
          "choices": [
            {
              "label": "track",
              "value": "track"
            },
            {
              "label": "page",
              "value": "page"
            },
            {
              "label": "screen",
              "value": "screen"
            }
          ],
          "placeholder": null,
          "properties": null,
          "category": null,
          "depends_on": null,
          "readOnly": false,
          "hidden": true,
          "minimum": null,
          "maximum": null,
          "defaultObjectUI": null,
          "disabledInputMethods": null,
          "displayMode": null,
          "additionalProperties": false
