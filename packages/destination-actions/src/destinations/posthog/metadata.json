      "subscribe": "type = \"track\"",
      "mapping": {
        "event_type": "track",
        "event_name": {
          "@path": "$.event"
        },
        "distinct_id": {
          "@path": "$.userId"
        },
        "properties": {
          "@path": "$.properties"
        },
        "current_url": {
