{
  "slug": "actions-sftp",
  "name": "SFTP",
  "mode": "cloud",
  "description": "Sync Segment events to SFTP",
  "authentication": {
    "scheme": "custom",
    "fields": {
      "auth_type": {
        "label": "Authentication Type",
        "description": "The type of authentication to use for the SFTP connection",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": [
          {
            "label": "Username and Password",
            "value": "password"
          },
          {
            "label": "Username and SSH Key",
            "value": "ssh_key"
          }
        ],
        "default": "password",
        "depends_on": null
      },
      "sftp_host": {
        "label": "SFTP Host",
        "description": "The hostname or IP address of the SFTP server",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": null
      },
      "sftp_port": {
        "label": "SFTP Port",
        "description": "The port number for the SFTP connection",
        "type": "number",
        "required": false,
        "multiple": false,
        "choices": null,
        "default": 22,
        "depends_on": null
      },
      "sftp_username": {
        "label": "Username",
        "description": "Username for establishing an SFTP connection",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": null
      },
      "sftp_password": {
        "label": "Password",
        "description": "Password for establishing an SFTP connection",
        "type": "password",
        "required": false,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": {
          "conditions": [
            {
              "fieldKey": "auth_type",
              "operator": "is",
              "value": "password"
            }
          ]
        }
      },
      "sftp_ssh_key": {
        "label": "SSH Key",
        "description": "SSH Key for establishing an SFTP connection",
        "type": "password",
        "required": false,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": {
          "conditions": [
            {
              "fieldKey": "auth_type",
              "operator": "is",
              "value": "ssh_key"
            }
          ]
        }
      },
      "uploadStrategy": {
        "label": "Upload Strategy",
        "description": "Select the upload strategy to use when uploading files to the SFTP server.",
        "type": "string",
        "required": false,
        "multiple": false,
        "choices": [
          {
            "label": "Standard [Supported by all SFTP servers]",
            "value": "standard"
          },
          {
            "label": "Concurrent [Improves upload time but may not be supported by all SFTP servers. Test and enable if supported.]",
            "value": "concurrent"
          }
        ],
        "default": "standard",
        "depends_on": null
      }
    }
  },
