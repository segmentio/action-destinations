    {
      "slug": "trackEvent",
      "name": "Track Event",
      "description": "Submit an event to Gleap.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\" or type = \"page\" or type = \"screen\"",
      "fields": [
        {
          "fieldKey": "eventName",
          "type": "string",
          "label": "Event Name",
          "description": "The name of the event that occurred. Names are treated as case insensitive. Periods and dollar signs in event names are replaced with hyphens.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.event"
              },
              "then": {
                "@path": "$.event"
              },
              "else": {
                "@path": "$.name"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "eventName": {
                "title": "Event Name",
                "description": "The name of the event that occurred. Names are treated as case insensitive. Periods and dollar signs in event names are replaced with hyphens.",
