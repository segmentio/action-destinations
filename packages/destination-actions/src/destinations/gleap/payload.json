          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "title": "Event Type",
                "description": "The type of the Segment event",
                "type": "string",
                "enum": ["track", "page", "screen"]
              }
            },
            "required": ["type"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "pageUrl",
          "type": "string",
