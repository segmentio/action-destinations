            "type": "object",
            "additionalProperties": false,
            "properties": {
              "pageUrl": {
                "title": "Event Page URL",
                "description": "The associated page url of the Segment event",
                "type": "string",
                "format": "uri"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "date",
          "type": "datetime",
          "label": "Event Timestamp",
          "description": "The time the event took place in ISO 8601 format. Segment will convert to Unix before sending to Gleap.",
          "defaultValue": {
