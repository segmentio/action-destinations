  "supportsAudiences": true,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync Audience",
      "description": "Sync users to Taboola.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\"",
      "fields": [
        {
          "fieldKey": "external_audience_id",
          "type": "string",
          "label": "External Audience ID",
          "description": "The Audience ID from Taboola.",
          "defaultValue": {
            "@path": "$.context.personas.external_audience_id"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "external_audience_id": {
                "title": "External Audience ID",
                "description": "The Audience ID from Taboola.",
                "type": "string"
              }
            },
            "required": [
              "external_audience_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_key",
          "type": "string",
          "label": "Audience Key",
          "description": "Segment Audience key to which user identifier should be added or removed",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_key": {
                "title": "Audience Key",
                "description": "Segment Audience key to which user identifier should be added or removed",
                "type": "string"
              }
            },
            "required": [
              "segment_computation_key"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "audience",
              "value": "audience"
            },
            {
              "label": "journey_step",
              "value": "journey_step"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
                "type": "string",
                "enum": [
                  "audience",
                  "journey_step"
                ]
              }
            },
            "required": [
              "segment_computation_action"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "user_email",
          "type": "string",
          "label": "Email address",
          "description": "The user's email address",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.email"
              },
              "then": {
                "@path": "$.traits.email"
              },
              "else": {
                "@path": "$.context.traits.email"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "user_email": {
                "title": "Email address",
                "description": "The user's email address",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traits_or_props",
          "type": "object",
          "label": "Traits or properties object",
          "description": "A computed object for track and identify events. This field should not need to be edited.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties"
              },
              "then": {
                "@path": "$.properties"
              },
              "else": {
                "@path": "$.traits"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits_or_props": {
                "title": "Traits or properties object",
                "description": "A computed object for track and identify events. This field should not need to be edited.",
                "type": "object"
              }
            },
            "required": [
              "traits_or_props"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Batch events",
          "description": "When enabled, events will be batched before being sent to Taboola. In most cases, batching should be enabled.",
          "defaultValue": true,
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enable_batching": {
                "title": "Batch events",
                "description": "When enabled, events will be batched before being sent to Taboola. In most cases, batching should be enabled.",
                "type": "boolean"
              }
            },
            "required": [
              "enable_batching"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "device_id",
          "type": "string",
          "label": "Mobile Device ID",
          "description": "To send iOS and Android Device IDs include them as 'ios_id' and 'android_id' via the 'Customized Setup' option when connecting your Audience.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties.ios_id"
              },
              "then": {
                "@path": "$.properties.ios_id"
              },
              "else": {
                "@path": "$.properties.android_id"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "device_id": {
                "title": "Mobile Device ID",
                "description": "To send iOS and Android Device IDs include them as 'ios_id' and 'android_id' via the 'Customized Setup' option when connecting your Audience.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "batch_size",
          "type": "integer",
          "label": "Batch Size",
          "description": "Max Batch size to send to Taboola.",
          "defaultValue": 1000,
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batch_size": {
                "title": "Batch Size",
                "description": "Max Batch size to send to Taboola.",
                "type": "integer"
              }
            },
            "required": [
              "batch_size"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "action",
          "type": "string",
          "label": "Action",
          "description": "Action to perform on the audience.",
          "required": false,
          "multiple": false,
          "choices": [
            {
              "label": "Add",
              "value": "ADD"
            },
            {
              "label": "Remove",
              "value": "REMOVE"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "action": {
                "title": "Action",
                "description": "Action to perform on the audience.",
                "type": "string",
                "enum": [
                  "ADD",
                  "REMOVE"
                ]
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
