{
  "name": "Iterable Lists (Actions)",
  "description": "Sync Segment Engage Audiences to Iterable Lists",
  "basicOptions": [
    "apiKey",
    "iterableProjectType",
    "updateExistingUsersOnly",
    "globalUnsubscribe",
    "campaignId",
    "__segment_internal_engage_batch_sync",
    "__segment_internal_engage_support_audience_functions"
  ],
  "options": {
    "apiKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "To obtain the API Key, go to the Iterable app and naviate to Integrations > API Keys. Create a new API Key with the 'Server-Side' type.",
      "encrypt": true,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The apiKey property is required."]],
      "uIMetadata": null
    },
    "iterableProjectType": {
      "tags": ["authentication:test"],
      "default": "hybrid",
      "description": "Select the type of your Iterable project. Hybrid projects support both email and user ID based identification, while User ID-Based projects only support user ID based identification.",
      "encrypt": false,
      "hidden": false,
      "label": "Iterable Project Type",
      "private": true,
      "scope": "event_destination",
      "type": "select",
      "options": [
        {
          "value": "hybrid",
          "label": "Hybrid Project",
          "text": "Hybrid Project"
        },
        {
          "value": "userId",
          "label": "User ID-Based Project",
          "text": "User ID-Based Project"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "updateExistingUsersOnly": {
      "tags": [],
      "default": false,
      "description": "When true, Iterable ignores requests for unknown userIds and email addresses. This field is only relevant for non-email based Iterable projects: For email-based projects users will continue to be created in Iterable if a user is added or removed from a List.",
      "encrypt": false,
      "hidden": false,
      "label": "Update existing users only",
      "private": false,
      "scope": "audience_destination",
      "type": "boolean",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "globalUnsubscribe": {
      "tags": [],
      "default": false,
      "description": "Unsubscribe email from list's associated channel - essentially a global unsubscribe. Only valid when unsubscribing a user from a List.",
      "encrypt": false,
      "hidden": false,
      "label": "Channel Unsubscribe",
      "private": false,
      "scope": "audience_destination",
      "type": "boolean",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "campaignId": {
      "tags": [],
      "default": 0,
      "description": "The numeric Campaign ID to associate with the unsubscribe. Only valid when unsubscribing a user from a List.",
      "encrypt": false,
      "hidden": false,
      "label": "Campaign ID",
      "private": false,
      "scope": "audience_destination",
      "type": "number",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "__segment_internal_engage_batch_sync": {
      "private": true,
      "hidden": true,
      "encrypt": false,
      "readOnly": true,
      "validators": [],
      "label": "Indicates that this is a batched (or synced) destination on some schedule",
      "type": "boolean",
      "description": "Indicates that this is a batched (or synced) destination on some schedule",
      "default": true,
      "scope": "event_destination"
    },
    "__segment_internal_engage_support_audience_functions": {
      "private": true,
      "hidden": true,
      "encrypt": false,
      "readOnly": true,
      "validators": [],
      "label": "Supports Audience Functions (getAudience/createAudience)",
      "type": "boolean",
      "description": "Supports Audience Functions (getAudience/createAudience)",
      "default": true,
      "scope": "event_destination"
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": ["us-west-2", "eu-west-1"],
  "supportsAudiences": true,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync To Iterable Lists",
      "description": "Sync Segment Audience to Iterable Lists",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\" or type = \"track\"",
      "fields": [
        {
          "fieldKey": "email",
          "type": "string",
          "label": "Email",
          "description": "Email address of the user",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.email"
              },
              "then": {
                "@path": "$.traits.email"
              },
              "else": {
                "@path": "$.properties.email"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email": {
                "title": "Email",
                "description": "Email address of the user",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "userId",
          "type": "string",
          "label": "User ID",
          "description": "User ID",
          "defaultValue": {
            "@path": "$.userId"
