          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "userId": {
                "title": "User ID",
                "description": "User ID",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "dataFields",
          "type": "object",
          "label": "Additional traits or identifiers",
          "description": "Additional traits or identifiers to sync to Iterable. You will need to ensure these traits or objects are included via Event Settings > Customized Setup.",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dataFields": {
                "title": "Additional traits or identifiers",
                "description": "Additional traits or identifiers to sync to Iterable. You will need to ensure these traits or objects are included via Event Settings > Customized Setup.",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traitsOrProperties",
          "type": "object",
          "label": "Traits or Properties",
          "description": "Traits or Properties object from the identify() or track() call emitted by Engage",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits"
              },
              "then": {
                "@path": "$.traits"
              },
              "else": {
                "@path": "$.properties"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traitsOrProperties": {
                "title": "Traits or Properties",
                "description": "Traits or Properties object from the identify() or track() call emitted by Engage",
                "type": "object"
              }
            },
            "required": ["traitsOrProperties"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segmentAudienceKey",
          "type": "string",
          "label": "Segment Audience Key",
          "description": "Segment Audience Key. Maps to the Iterable List \"Name\" when the list is created in Iterable.",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segmentAudienceKey": {
                "title": "Segment Audience Key",
                "description": "Segment Audience Key. Maps to the Iterable List \"Name\" when the list is created in Iterable.",
                "type": "string"
              }
            },
            "required": ["segmentAudienceKey"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segmentAudienceId",
          "type": "string",
          "label": "Segment External Audience ID",
          "description": "Segment External Audience ID. Maps to the List ID when the list is created in Iterable.",
          "defaultValue": {
            "@path": "$.context.personas.external_audience_id"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segmentAudienceId": {
                "title": "Segment External Audience ID",
                "description": "Segment External Audience ID. Maps to the List ID when the list is created in Iterable.",
                "type": "string"
              }
            },
            "required": ["segmentAudienceId"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Enable Batching?",
          "description": "When enabled, Segment will send events in batches.",
          "defaultValue": false,
          "required": false,
          "multiple": false,
          "dynamic": false,
          "allowNull": false,
          "choices": null
        }
      ]
    }
  ],
