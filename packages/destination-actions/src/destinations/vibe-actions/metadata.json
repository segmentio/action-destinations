    {
      "name": "Order Completed",
      "type": "automatic",
      "partnerAction": "trackConversionEvent",
      "subscribe": "type = \"track\" and event = \"Order Completed\"",
      "mapping": {
        "eventId": {
          "@path": "$.messageId"
        },
        "timestamp": {
          "@path": "$.timestamp"
        },
        "email": {
          "@if": {
