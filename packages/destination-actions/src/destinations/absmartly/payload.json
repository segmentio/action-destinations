{
  "name": "ABsmartly (Actions)",
  "description": "ABsmartly is an online experimentation service. Send events to ABsmartly to track experiments and goals.",
  "basicOptions": [
    "collectorEndpoint",
    "apiKey",
    "environment"
  ],
  "options": {
    "collectorEndpoint": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "ABsmartly Collector endpoint, for example: https://you-subdomain.absmartly.io/v1 - Contact ABsmartly Support if you don't know your Collector Endpoint.",
      "encrypt": false,
      "hidden": false,
      "label": "Collector Endpoint",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The collectorEndpoint property is required."
        ]
      ],
      "uIMetadata": null
    },
    "apiKey": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "ABsmartly SDK API Key. Create SDK Api Keys in the Settings > API Keys section of the ABsmartly Web Console",
      "encrypt": false,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The apiKey property is required."
        ]
      ],
      "uIMetadata": null
    },
    "environment": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Environment name. Environment name needs to match what's in the Web Console. Create Environments in the Settings > Environments section of the ABsmartly Web Console",
      "encrypt": false,
      "hidden": false,
      "label": "Environment",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The environment property is required."
        ]
      ],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "trackExposure",
      "name": "Track Exposure",
      "description": "Send an experiment exposure event to ABsmartly",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\" and event = \"Experiment Viewed\"",
      "fields": [
        {
          "fieldKey": "exposure",
          "type": "object",
          "label": "ABsmartly Exposure Payload",
          "description": "The ABsmartly exposure payload without any goals. Generated by the ABsmartly SDK and should not be modified.",
          "defaultValue": {
            "@path": "$.properties.exposure"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "defaultObjectUI": "object:only",
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "exposure": {
                "title": "ABsmartly Exposure Payload",
                "description": "The ABsmartly exposure payload without any goals. Generated by the ABsmartly SDK and should not be modified.",
                "type": "object"
              }
            },
            "required": [
              "exposure"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "agent",
          "type": "string",
          "label": "Agent",
          "description": "Optional agent identifier that originated the event. Used to identify which SDK generated the event.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.context.library.name"
              },
              "then": {
                "@path": "$.context.library.name"
              },
              "else": "segment"
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "agent": {
                "title": "Agent",
                "description": "Optional agent identifier that originated the event. Used to identify which SDK generated the event.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "application",
          "type": "string",
          "label": "Application",
          "description": "Optional application name that originated this event. Must exist if not empty. Create Applications in the Settings > Applications section of the ABsmartly Web Console",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "application": {
                "title": "Application",
                "description": "Optional application name that originated this event. Must exist if not empty. Create Applications in the Settings > Applications section of the ABsmartly Web Console",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    },
    {
      "slug": "trackGoal",
      "name": "Track Goal",
      "description": "Send a goal event to ABsmartly",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\" and event != \"Experiment Viewed\"",
      "fields": [
        {
          "fieldKey": "units",
          "type": "object",
          "label": "Units",
          "description": "The units of the goal to track. Mapping of unit name to source property in the event payload. Create Units in the Settings > Units section of the ABsmartly Web Console",
          "defaultValue": {
            "anonymousId": {
              "@path": "$.anonymousId"
            },
            "userId": {
              "@path": "$.userId"
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "defaultObjectUI": "keyvalue:only",
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "units": {
                "title": "Units",
                "description": "The units of the goal to track. Mapping of unit name to source property in the event payload. Create Units in the Settings > Units section of the ABsmartly Web Console",
                "type": "object"
              }
            },
            "required": [
              "units"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "name",
          "type": "string",
          "label": "Goal Name",
          "description": "The name of the goal to track",
          "defaultValue": {
            "@path": "$.event"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "title": "Goal Name",
                "description": "The name of the goal to track",
                "type": "string"
              }
            },
            "required": [
              "name"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "properties",
          "type": "object",
          "label": "Goal Properties",
          "description": "Custom properties of the goal",
          "defaultValue": {
            "@path": "$.properties"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "properties": {
                "title": "Goal Properties",
                "description": "Custom properties of the goal",
                "type": "object"
              }
            },
            "required": [
              "properties"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "agent",
          "type": "string",
          "label": "Agent",
          "description": "Optional agent identifier that originated the event. Used to identify which SDK generated the event.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.context.library.name"
              },
              "then": {
                "@path": "$.context.library.name"
              },
              "else": "segment"
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "agent": {
                "title": "Agent",
                "description": "Optional agent identifier that originated the event. Used to identify which SDK generated the event.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "application",
          "type": "string",
          "label": "Application",
          "description": "Optional application name that originated this event. Must exist if not empty. Create Applications in the Settings > Applications section of the ABsmartly Web Console",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "application": {
                "title": "Application",
                "description": "Optional application name that originated this event. Must exist if not empty. Create Applications in the Settings > Applications section of the ABsmartly Web Console",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": [
    {
      "partnerAction": "trackExposure",
      "name": "Exposures (Verbatim)",
      "subscribe": "type = \"track\" and event = \"Experiment Viewed\"",
      "mapping": {
        "exposure": {
          "@path": "$.properties.exposure"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "trackGoal",
      "name": "Page Calls",
      "subscribe": "type = \"page\"",
      "mapping": {
        "units": {
          "anonymousId": {
            "@path": "$.anonymousId"
          },
          "userId": {
            "@path": "$.userId"
          }
        },
        "name": {
          "@template": "Page: {{ name }}"
        },
        "properties": {
          "@path": "$.properties"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "trackGoal",
      "name": "Screen Calls",
      "subscribe": "type = \"screen\"",
      "mapping": {
        "units": {
          "anonymousId": {
            "@path": "$.anonymousId"
          },
          "userId": {
            "@path": "$.userId"
          }
        },
        "name": {
          "@template": "Screen: {{ name }}"
        },
        "properties": {
          "@path": "$.properties"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "trackGoal",
      "name": "Track Calls",
      "subscribe": "type = \"track\" and event != \"Experiment Viewed\"",
      "mapping": {
        "units": {
          "anonymousId": {
            "@path": "$.anonymousId"
          },
          "userId": {
            "@path": "$.userId"
          }
        },
        "name": {
          "@path": "$.event"
        },
        "properties": {
          "@path": "$.properties"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "type": "automatic"
    }
  ]
}
