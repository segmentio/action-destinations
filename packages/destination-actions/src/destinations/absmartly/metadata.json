  "presets": [
    {
      "name": "Track Calls",
      "type": "automatic",
      "partnerAction": "trackGoal",
      "subscribe": "type = \"track\" and event != \"Experiment Viewed\"",
      "mapping": {
        "units": {
          "anonymousId": {
            "@path": "$.anonymousId"
          },
          "userId": {
            "@path": "$.userId"
          }
        },
        "name": {
          "@path": "$.event"
        },
        "properties": {
          "@path": "$.properties"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "eventSlug": null
    },
    {
      "name": "Page Calls",
      "type": "automatic",
      "partnerAction": "trackGoal",
      "subscribe": "type = \"page\"",
      "mapping": {
        "units": {
          "anonymousId": {
            "@path": "$.anonymousId"
          },
          "userId": {
            "@path": "$.userId"
          }
        },
        "name": {
          "@template": "Page: {{ name }}"
        },
        "properties": {
          "@path": "$.properties"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "eventSlug": null
    },
    {
      "name": "Screen Calls",
      "type": "automatic",
      "partnerAction": "trackGoal",
      "subscribe": "type = \"screen\"",
      "mapping": {
        "units": {
          "anonymousId": {
            "@path": "$.anonymousId"
          },
          "userId": {
            "@path": "$.userId"
          }
        },
        "name": {
          "@template": "Screen: {{ name }}"
        },
        "properties": {
          "@path": "$.properties"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "eventSlug": null
    },
    {
      "name": "Exposures (Verbatim)",
      "type": "automatic",
      "partnerAction": "trackExposure",
      "subscribe": "type = \"track\" and event = \"Experiment Viewed\"",
      "mapping": {
        "exposure": {
          "@path": "$.properties.exposure"
        },
        "agent": {
          "@if": {
            "exists": {
              "@path": "$.context.library.name"
            },
            "then": {
              "@path": "$.context.library.name"
            },
            "else": "segment"
          }
        }
      },
      "eventSlug": null
    }
  ]
