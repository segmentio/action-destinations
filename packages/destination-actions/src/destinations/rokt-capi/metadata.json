                    "type": "string"
                  },
                  "billingzipcode": {
                    "title": "Billing Zip Code",
                    "description": "User billing zip code.",
                    "type": "string"
                  },
                  "dob": {
                    "title": "Date of Birth",
                    "description": "User date of birth in ISO8601 format (YYYY-MM-DD).",
