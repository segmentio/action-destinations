{
  "name": "Rokt Conversions API",
  "basicOptions": [
    "apiKey",
    "apiSecret"
  ],
  "options": {
    "apiKey": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Your Rokt CAPI API Key. Contact your Rokt representative to obtain this value.",
      "encrypt": true,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The apiKey property is required."
        ]
      ],
      "uIMetadata": null
    },
    "apiSecret": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Your Rokt CAPI API Secret. Contact your Rokt representative to obtain this value.",
      "encrypt": true,
      "hidden": false,
      "label": "API Secret",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The apiSecret property is required."
        ]
      ],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "roktPlugin",
      "name": "Rokt Browser Plugin",
      "description": "Enriches all Segment payloads with Rokt rtid Querystring value",
      "platform": "web",
      "hidden": false,
      "defaultTrigger": "type = \"track\" or type = \"identify\" or type = \"page\" or type = \"group\" or type = \"alias\"",
      "fields": []
    },
    {
      "slug": "send",
      "name": "Send",
      "description": "Send analytics data to Rokt CAPI.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": null,
      "fields": [
        {
          "fieldKey": "eventDetails",
          "type": "object",
          "label": "Event Details",
          "description": "Details about the event to be sent to Rokt CAPI.",
          "defaultValue": {
            "conversiontype": {
              "@path": "$.event"
            },
            "confirmationref": {
              "@path": "$.properties.order_id"
            },
            "amount": {
              "@path": "$.properties.revenue"
            },
            "currency": {
              "@path": "$.properties.currency"
            },
            "source_message_id": {
              "@path": "$.messageId"
            },
            "timestamp_unixtime_ms": {
              "@path": "$.timestamp"
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "defaultObjectUI": "keyvalue:only",
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "eventDetails": {
                "title": "Event Details",
                "description": "Details about the event to be sent to Rokt CAPI.",
                "type": "object",
                "$schema": "http://json-schema.org/schema#",
                "additionalProperties": false,
                "properties": {
                  "conversiontype": {
                    "title": "Conversion Type",
                    "description": "Type of conversion, This should usually be mapped to the Segment track() event name. e.g., \"Order Completed\".",
                    "type": "string"
                  },
                  "confirmationref": {
                    "title": "Confirmation Reference",
                    "description": "Unique ID for the conversion, ideally an order ID.",
                    "type": "string"
                  },
                  "amount": {
                    "title": "Amount",
                    "description": "Monetary amount associated with the conversion.",
                    "type": "number"
                  },
                  "currency": {
                    "title": "Currency",
                    "description": "3-letter ISO currency code (e.g. USD, EUR).",
                    "type": "string"
                  },
                  "source_message_id": {
                    "title": "Source Message ID",
                    "description": "Unique identifier for the source message.",
                    "type": "string"
                  },
                  "timestamp_unixtime_ms": {
                    "title": "Event Timestamp",
                    "description": "Event timestamp in Unix time milliseconds.",
                    "type": "string"
                  }
                },
                "required": [
                  "source_message_id",
                  "timestamp_unixtime_ms"
                ]
              }
            },
            "required": [
              "eventDetails"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "eventProperties",
          "type": "object",
          "label": "Additional Custom Attributes",
          "description": "Additional custom attributes for the event.",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "defaultObjectUI": "keyvalue",
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "eventProperties": {
                "title": "Additional Custom Attributes",
                "description": "Additional custom attributes for the event.",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "hashingConfiguration",
          "type": "object",
          "label": "Hashing Configuration",
          "description": "Specify if email and certain user attributes should be hashed before sending.",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "defaultObjectUI": "keyvalue:only",
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hashingConfiguration": {
                "title": "Hashing Configuration",
                "description": "Specify if email and certain user attributes should be hashed before sending.",
                "type": "object",
                "$schema": "http://json-schema.org/schema#",
                "additionalProperties": false,
                "properties": {
                  "hashEmail": {
                    "title": "Hash Email",
                    "description": "If enabled, Segment will ensure that the email address is hashed using SHA256 before sending.",
                    "type": "boolean",
                    "default": false
                  },
                  "hashFirstName": {
                    "title": "Hash First Name",
                    "description": "If enabled, Segment will ensure that the first name is hashed using SHA256 before sending.",
                    "type": "boolean",
                    "default": false
                  },
                  "hashLastName": {
                    "title": "Hash Last Name",
                    "description": "If enabled, Segment will ensure that the last name is hashed using SHA256 before sending.",
                    "type": "boolean",
                    "default": false
                  },
                  "hashMobile": {
                    "title": "Hash Mobile Number",
                    "description": "If enabled, Segment will ensure that the mobile number is hashed using SHA256 before sending.",
                    "type": "boolean",
                    "default": false
                  },
                  "hashBillingZipcode": {
                    "title": "Hash Billing Zip Code",
                    "description": "If enabled, Segment will ensure that the billing zip code is hashed using SHA256 before sending.",
                    "type": "boolean",
                    "default": false
                  }
                },
                "required": []
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "device_info",
          "type": "object",
          "label": "Device Information",
          "description": "Information about the user device.",
          "defaultValue": {
            "http_header_user_agent": {
              "@path": "$.context.userAgent"
            },
            "ios_advertising_id": {
              "@liquid": "{% if context.device.advertisingId and context.device.type == 'ios' %}{{ context.device.advertisingId }}{% endif %}"
            },
            "android_advertising_id": {
              "@liquid": "{% if context.device.advertisingId and context.device.type == 'android' %}{{ context.device.advertisingId }}{% endif %}"
            },
            "ios_idfv": {
              "@liquid": "{% if context.device.id and context.device.type == 'ios' %}{{ context.device.id }}{% endif %}"
            },
            "android_uuid": {
              "@liquid": "{% if context.device.id and context.device.type == 'android' %}{{ context.device.id }}{% endif %}"
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "device_info": {
                "title": "Device Information",
                "description": "Information about the user device.",
                "type": "object",
                "$schema": "http://json-schema.org/schema#",
                "additionalProperties": false,
                "properties": {
                  "http_header_user_agent": {
                    "title": "User Agent",
                    "description": "Device user agent.",
                    "type": "string"
                  },
                  "ios_advertising_id": {
                    "title": "iOS Advertising ID",
                    "description": "Advertising ID from an iOS mobile device.",
                    "type": "string"
                  },
                  "android_advertising_id": {
                    "title": "Android Advertising ID",
                    "description": "Advertising ID from an Android mobile device.",
                    "type": "string"
                  },
                  "ios_idfv": {
                    "title": "iOS ID for Vendor",
                    "description": "ID for Vendor from an iOS mobile device.",
                    "type": "string"
                  },
                  "android_uuid": {
                    "title": "Android UUID",
                    "description": "UUID from an Android mobile device.",
                    "type": "string"
                  }
                },
                "required": []
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "user_identities",
          "type": "object",
          "label": "User Identities",
          "description": "Unique user identifiers used to identify the user. At least one identifier is required, or the advertising ID in device info.",
          "defaultValue": {
            "email": {
              "@if": {
                "exists": {
                  "@path": "$.traits.email"
                },
                "then": {
                  "@path": "$.traits.email"
                },
                "else": {
                  "@path": "$.properties.email"
                }
              }
            },
            "customerid": {
              "@path": "$.userId"
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "user_identities": {
                "title": "User Identities",
                "description": "Unique user identifiers used to identify the user. At least one identifier is required, or the advertising ID in device info.",
                "type": "object",
                "$schema": "http://json-schema.org/schema#",
                "additionalProperties": false,
                "properties": {
                  "email": {
                    "title": "Email",
                    "description": "User email address. This can be in plain text or hashed using SHA256. If you send plain text and would like Segment to hash the email address for you, enable the \"Hash Email\" field.",
                    "type": "string"
                  },
                  "customerid": {
                    "title": "Customer ID",
                    "description": "Unique customer identifier.",
                    "type": "string"
                  }
                },
                "required": []
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
