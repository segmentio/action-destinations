{
  "slug": "actions-rokt-audiences",
  "name": "Rokt Audiences (Actions)",
  "mode": "cloud",
  "description": "\n  This destination allows user to engage audiences using Rokt's Public APIs.\n  User can connect Rokt Audiences (Actions) as a destination to their Engage Audience in Segment,\n  which will create/update custom audiences in the Rokt data platform. Audiences can be defined with either\n  email values or hashed (sha256) email values.\n  ",
  "authentication": {
    "scheme": "custom",
    "fields": {
      "rpub": {
        "label": "Rokt public key",
        "description": "Rokt public key, starts with `rpub-`",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": null
      },
      "rsec": {
        "label": "Rokt secret key",
        "description": "Rokt secret key, starts with `rsec-`",
        "type": "password",
        "required": true,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": null
      },
      "accountid": {
        "label": "Rokt Account ID",
        "description": "Rokt ID assigned to your particular account.",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": null
      }
    }
  },
  "audienceConfig": null,
  "actions": {
    "upsertCustomAudiences": {
      "title": "Sync Engage Audience to Rokt",
      "description": "Add/Remove users from Rokt custom audience list. Both identify() and track() calls are supported",
