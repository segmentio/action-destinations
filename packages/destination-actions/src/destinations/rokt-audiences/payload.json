{
  "name": "Rokt Audiences (Actions)",
  "description": "\n  This destination allows user to engage audiences using Rokt's Public APIs.\n  User can connect Rokt Audiences (Actions) as a destination to their Engage Audience in Segment,\n  which will create/update custom audiences in the Rokt data platform. Audiences can be defined with either\n  email values or hashed (sha256) email values.\n  ",
  "basicOptions": [
    "rpub",
    "rsec",
    "accountid"
  ],
  "options": {
    "rpub": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Rokt public key, starts with `rpub-`",
      "encrypt": false,
      "hidden": false,
      "label": "Rokt public key",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The rpub property is required."
        ]
      ],
      "uIMetadata": null
    },
    "rsec": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Rokt secret key, starts with `rsec-`",
      "encrypt": true,
      "hidden": false,
      "label": "Rokt secret key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The rsec property is required."
        ]
      ],
      "uIMetadata": null
    },
    "accountid": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Rokt ID assigned to your particular account.",
      "encrypt": false,
      "hidden": false,
      "label": "Rokt Account ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The accountid property is required."
        ]
      ],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "upsertCustomAudiences",
      "name": "Sync Engage Audience to Rokt",
      "description": "Add/Remove users from Rokt custom audience list. Both identify() and track() calls are supported",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\" or type = \"identify\"",
      "fields": [
        {
          "fieldKey": "custom_audience_name",
          "type": "string",
          "label": "Custom Audience Name",
          "description": "Name of custom audience list to which emails should added/removed",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "custom_audience_name": {
                "title": "Custom Audience Name",
                "description": "Name of custom audience list to which emails should added/removed",
                "type": "string"
              }
            },
            "required": [
              "custom_audience_name"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Segment computation class used to determine if action is an 'Engage-Audience'",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Segment computation class used to determine if action is an 'Engage-Audience'",
                "type": "string"
              }
            },
            "required": [
              "segment_computation_action"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "email",
          "type": "string",
          "label": "Email",
          "description": "User's email address to be included/excluded from the custom audience.  One of either email_sha256 or email must be specified.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.context.traits.email"
              },
              "then": {
                "@path": "$.context.traits.email"
              },
              "else": {
                "@path": "$.traits.email"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email": {
                "title": "Email",
                "description": "User's email address to be included/excluded from the custom audience.  One of either email_sha256 or email must be specified.",
                "type": "string",
                "format": "email"
              }
            },
            "required": [],
            "allOf": [
              {
                "if": {
                  "anyOf": [
                    {
                      "not": {
                        "required": [
                          "email_sha256"
                        ]
                      }
                    },
                    {
                      "properties": {
                        "email_sha256": {
                          "type": "null"
                        }
                      }
                    }
                  ]
                },
                "then": {
                  "required": [
                    "email"
                  ]
                }
              }
            ]
          },
          "dependsOn": null,
          "displayMetadata": {
            "conditionallyRequired": {
              "conditions": [
                {
                  "fieldKey": "email_sha256",
                  "operator": "is"
                }
              ]
            }
          }
        },
        {
          "fieldKey": "email_sha256",
          "type": "string",
          "label": "Email SHA256",
          "description": "User's SHA256-hashed email address to be included/excluded from the custom audience. One of either email_sha256 or email must be specified.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.context.traits.email_sha256"
              },
              "then": {
                "@path": "$.context.traits.email_sha256"
              },
              "else": {
                "@path": "$.traits.email_sha256"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email_sha256": {
                "title": "Email SHA256",
                "description": "User's SHA256-hashed email address to be included/excluded from the custom audience. One of either email_sha256 or email must be specified.",
                "type": "string",
                "format": "text"
              }
            },
            "required": [],
            "allOf": [
              {
                "if": {
                  "anyOf": [
                    {
                      "not": {
                        "required": [
                          "email"
                        ]
                      }
                    },
                    {
                      "properties": {
                        "email": {
                          "type": "null"
                        }
                      }
                    }
                  ]
                },
                "then": {
                  "required": [
                    "email_sha256"
                  ]
                }
              }
            ]
          },
          "dependsOn": null,
          "displayMetadata": {
            "conditionallyRequired": {
              "conditions": [
                {
                  "fieldKey": "email",
                  "operator": "is"
                }
              ]
            }
          }
        },
        {
          "fieldKey": "traits_or_props",
          "type": "object",
          "label": "traits or properties object",
          "description": "Object which will be computed differently for track and identify events",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties"
              },
              "then": {
                "@path": "$.properties"
              },
              "else": {
                "@path": "$.traits"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits_or_props": {
                "title": "traits or properties object",
                "description": "Object which will be computed differently for track and identify events",
                "type": "object"
              }
            },
            "required": [
              "traits_or_props"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "enable batching to rokt api",
          "description": "Set as true to ensure Segment infrastructure uses batching when possible.",
          "defaultValue": true,
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enable_batching": {
                "title": "enable batching to rokt api",
                "description": "Set as true to ensure Segment infrastructure uses batching when possible.",
                "type": "boolean"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": [
    {
      "partnerAction": "upsertCustomAudiences",
      "name": "Sync Engage Audience to Rokt",
      "subscribe": "type = \"track\" or type = \"identify\"",
      "mapping": {
        "custom_audience_name": {
          "@path": "$.context.personas.computation_key"
        },
        "segment_computation_action": {
          "@path": "$.context.personas.computation_class"
        },
        "email": {
          "@if": {
            "exists": {
              "@path": "$.context.traits.email"
            },
            "then": {
              "@path": "$.context.traits.email"
            },
            "else": {
              "@path": "$.traits.email"
            }
          }
        },
        "email_sha256": {
          "@if": {
            "exists": {
              "@path": "$.context.traits.email_sha256"
            },
            "then": {
              "@path": "$.context.traits.email_sha256"
            },
            "else": {
              "@path": "$.traits.email_sha256"
            }
          }
        },
        "traits_or_props": {
          "@if": {
            "exists": {
              "@path": "$.properties"
            },
            "then": {
              "@path": "$.properties"
            },
            "else": {
              "@path": "$.traits"
            }
          }
        },
        "enable_batching": true
      },
      "type": "automatic"
    }
  ]
}
