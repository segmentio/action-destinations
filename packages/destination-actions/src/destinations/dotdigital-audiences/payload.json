  "supportedRegions": ["us-west-2", "eu-west-1"],
  "supportsAudiences": true,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync Audience",
      "description": "Sync Segment Engage Audience to a Dotdigital List",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\" or type = \"track\"",
      "fields": [
        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "audience",
              "value": "audience"
            },
            {
              "label": "journey_step",
              "value": "journey_step"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
                "type": "string",
                "enum": ["audience", "journey_step"]
              }
            },
            "required": ["segment_computation_action"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "computation_key",
          "type": "string",
          "label": "Audience Computation Key",
          "description": "Segment's friendly name for the Audience",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": true,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "computation_key": {
                "title": "Audience Computation Key",
                "description": "Segment's friendly name for the Audience",
                "type": "string"
              }
            },
            "required": ["computation_key"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "external_audience_id",
          "type": "string",
          "label": "Audience ID",
          "description": "Unique Audience Identifier returned by the createAudience() function call.",
          "defaultValue": {
            "@path": "$.context.personas.external_audience_id"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "external_audience_id": {
                "title": "Audience ID",
                "description": "Unique Audience Identifier returned by the createAudience() function call.",
                "type": "string"
              }
            },
            "required": ["external_audience_id"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "emailIdentifier",
          "type": "string",
          "label": "Email address",
          "description": "The Contact's email address.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.email"
              },
              "then": {
                "@path": "$.traits.email"
              },
              "else": {
                "@path": "$.properties.email"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "emailIdentifier": {
                "title": "Email address",
                "description": "The Contact's email address.",
                "type": "string",
                "format": "email"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "mobileNumberIdentifier",
          "type": "string",
          "label": "Mobile Number",
          "description": "The Contact's mobile number.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.phone"
              },
              "then": {
                "@path": "$.traits.phone"
              },
              "else": {
                "@path": "$.properties.phone"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mobileNumberIdentifier": {
                "title": "Mobile Number",
                "description": "The Contact's mobile number.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traits_or_props",
          "type": "object",
          "label": "Traits or properties object",
          "description": "A computed object for track and identify events. This field should not need to be edited.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties"
              },
              "then": {
                "@path": "$.properties"
              },
              "else": {
                "@path": "$.traits"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits_or_props": {
                "title": "Traits or properties object",
                "description": "A computed object for track and identify events. This field should not need to be edited.",
                "type": "object"
              }
            },
            "required": ["traits_or_props"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "dataFields",
          "type": "object",
          "label": "Data Fields",
          "description": "An object containing key/value pairs for data fields assigned to this Contact. Custom Data Fields must already be defined in Dotdigital.",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": true,
          "placeholder": "",
          "allowNull": false,
          "defaultObjectUI": "keyvalue:only",
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dataFields": {
                "title": "Data Fields",
                "description": "An object containing key/value pairs for data fields assigned to this Contact. Custom Data Fields must already be defined in Dotdigital.",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": {
            "dynamicProperties": ["__keys__"]
          }
        }
      ]
    }
