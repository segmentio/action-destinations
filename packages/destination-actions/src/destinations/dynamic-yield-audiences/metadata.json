      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Dynamic Yield by Mastercard Section ID",
      "encrypt": false,
      "hidden": false,
      "label": "Section ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The sectionId property is required."
        ]
      ],
      "uIMetadata": null
    },
    "accessKey": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
