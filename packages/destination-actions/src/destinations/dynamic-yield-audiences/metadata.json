{
  "name": "Dynamic Yield by Mastercard Audiences",
  "description": "Sync [Segment Audiences](https://segment.com/docs/engage/audiences/) to Dynamic Yield by Mastercard.",
  "basicOptions": [
    "sectionId",
    "accessKey",
    "audience_name",
    "identifier_type",
    "dy_identifier_type",
    "__segment_internal_engage_batch_sync",
    "__segment_internal_engage_support_audience_functions"
  ],
