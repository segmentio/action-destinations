            "required": [
              "external_audience_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_audience_key",
          "type": "string",
          "label": "Audience Key",
          "description": "Segment Audience key / name",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_audience_key": {
                "title": "Audience Key",
                "description": "Segment Audience key / name",
                "type": "string"
              }
            },
            "required": [
              "segment_audience_key"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traits_or_props",
          "type": "object",
          "label": "Traits or Properties",
          "description": "Traits or Properties object",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits"
              },
              "then": {
                "@path": "$.traits"
              },
              "else": {
                "@path": "$.properties"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits_or_props": {
                "title": "Traits or Properties",
