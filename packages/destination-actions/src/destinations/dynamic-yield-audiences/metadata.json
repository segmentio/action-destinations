      "hidden": false,
      "label": "Dynamic Yield Identifier Type (optional)",
      "private": false,
      "scope": "audience_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
