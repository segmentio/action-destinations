          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "message_id": {
                "title": "Message ID",
                "description": "Segment event message ID",
                "type": "string"
              }
            },
            "required": [
              "message_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "timestamp",
          "type": "datetime",
          "label": "Timestamp",
          "description": "Segment event timestamp",
          "defaultValue": {
            "@path": "$.timestamp"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "timestamp": {
                "title": "Timestamp",
                "description": "Segment event timestamp",
                "type": [
                  "string",
                  "number"
                ],
                "format": "date-like"
