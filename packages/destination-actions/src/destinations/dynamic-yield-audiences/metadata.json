        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "audience",
              "value": "audience"
            },
            {
              "label": "journey_step",
              "value": "journey_step"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
                "type": "string",
                "enum": [
                  "audience",
                  "journey_step"
                ]
              }
            },
            "required": [
              "segment_computation_action"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "email",
          "type": "string",
          "label": "Email",
          "description": "User's email address. If not hashed, Segment will hash this value.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.email"
              },
              "then": {
                "@path": "$.traits.email"
              },
              "else": {
                "@path": "$.context.traits.email"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email": {
                "title": "Email",
                "description": "User's email address. If not hashed, Segment will hash this value.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": {
            "category": "hashedPII"
          }
        },
        {
          "fieldKey": "anonymousId",
          "type": "string",
          "label": "Segment Anonymous Id",
          "description": "User's anonymousId",
          "defaultValue": {
            "@path": "$.anonymousId"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "anonymousId": {
                "title": "Segment Anonymous Id",
                "description": "User's anonymousId",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "userId",
          "type": "string",
          "label": "Segment User Id",
          "description": "User's unique User ID",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "userId": {
                "title": "Segment User Id",
                "description": "User's unique User ID",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
