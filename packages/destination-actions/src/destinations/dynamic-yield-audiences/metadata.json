      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The accessKey property is required."
        ]
      ],
      "uIMetadata": null
    },
    "audience_name": {
      "tags": [],
      "default": "",
      "description": "Provide a name for your Audience to be displayed in Dynamic Yield by Mastercard.",
      "encrypt": false,
      "hidden": false,
      "label": "Audience Name",
      "private": false,
      "scope": "audience_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The audience_name property is required."
        ]
      ],
      "uIMetadata": null
    },
    "identifier_type": {
      "tags": [],
      "default": "",
      "description": "The Segment identifier to send to Dynamic Yield by Mastercard. E.g. `email`, `anonymousId`, `userId` or any other custom identifier. Make sure to configure the identifier in the `Customized Setup` below so that it is sent to Dynamic Yield by Mastercard.",
