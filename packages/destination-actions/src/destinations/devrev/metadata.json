      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Your DevRev API Key, generated from the setting page in your DevRev organization.",
      "encrypt": true,
      "hidden": false,
      "label": "DevRev API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
