      "tags": [
        "authentication:test"
      ],
      "default": "gmail.com,hotmail.com,outlook.com,yahoo.com,aol.com,icloud.com,me.com,msn.com",
      "description": "A comma separated list of email domains to blacklist from being used to search for/create Accounts.",
