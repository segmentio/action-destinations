  "presets": [
    {
      "name": "Track Calls",
      "type": "automatic",
      "partnerAction": "receiveEvents",
      "subscribe": "type = \"track\"",
      "mapping": {
        "uniqueRecipientId": {
          "@if": {
            "exists": {
              "@path": "$.properties.email"
            },
            "then": {
              "@path": "$.properties.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
          "@path": "$.timestamp"
        }
      },
      "eventSlug": null
    },
    {
      "name": "Identify Calls",
      "type": "automatic",
      "partnerAction": "receiveEvents",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "uniqueRecipientId": {
          "@if": {
            "exists": {
              "@path": "$.traits.email"
            },
            "then": {
              "@path": "$.traits.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
