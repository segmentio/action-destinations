  "presets": [
    {
      "partnerAction": "receiveEvents",
      "name": "Identify Calls",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "uniqueRecipientId": {
          "@if": {
            "exists": {
              "@path": "$.traits.email"
            },
            "then": {
              "@path": "$.traits.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
          "@path": "$.timestamp"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "receiveEvents",
      "name": "Track Calls",
      "subscribe": "type = \"track\"",
      "mapping": {
        "uniqueRecipientId": {
          "@if": {
            "exists": {
              "@path": "$.properties.email"
            },
            "then": {
              "@path": "$.properties.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
          "@path": "$.timestamp"
        }
      },
      "type": "automatic"
    }
  ]
}
