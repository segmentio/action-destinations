  "actions": [
    {
      "slug": "receiveEvents",
      "name": "Send Events",
      "description": "Send Segment identify() and track() events to Acoustic Connect. At least one of the following optional fields should be populated: Key-Value pairs, Arrays, Context, Properties, Traits.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": null,
      "fields": [
        {
          "fieldKey": "key_value_pairs",
          "type": "object",
          "label": "Key-Value pairs",
          "description": "Map simple Key-Value pairs (optional) ",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
