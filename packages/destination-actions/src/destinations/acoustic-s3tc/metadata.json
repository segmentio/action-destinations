                "title": "Arrays",
                "description": "If the data needed is in an array, use this section to Map Array data into useable attributes (optional) ",
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
