      "uIMetadata": null
    },
    "s3_aws_bucket_name": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Name of the S3 bucket where the files will be uploaded to.",
      "encrypt": false,
      "hidden": false,
      "label": "AWS Bucket Name",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The s3_aws_bucket_name property is required."]],
      "uIMetadata": null
    },
    "s3_aws_region": {
      "tags": ["authentication:test"],
      "default": "",
