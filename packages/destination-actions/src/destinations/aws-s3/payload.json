          "value": ",",
          "label": "comma",
          "text": "comma"
        },
        {
          "value": "|",
          "label": "pipe",
          "text": "pipe"
        },
        {
          "value": "tab",
          "label": "tab",
          "text": "tab"
        },
        {
          "value": ";",
          "label": "semicolon",
          "text": "semicolon"
        },
        {
          "value": ":",
          "label": "colon",
          "text": "colon"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The delimiter property is required."]],
      "uIMetadata": null
    },
