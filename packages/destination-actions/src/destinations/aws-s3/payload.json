      "encrypt": false,
      "hidden": false,
      "label": "AWS Region Code (S3 only)",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The s3_aws_region property is required."]],
      "uIMetadata": null
    },
    "iam_external_id": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "The External ID to your IAM role. Generate a secure string and treat it like a password.",
      "encrypt": true,
      "hidden": false,
      "label": "IAM External ID",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The iam_external_id property is required."]],
      "uIMetadata": null
    },
    "s3_aws_folder_name": {
      "tags": [],
      "default": "",
      "description": "Name of the S3 Subfolder where the files will be uploaded to. e.g. segmentdata/ or segmentdata/audiences/",
      "encrypt": false,
      "hidden": false,
      "label": "AWS Subfolder Name",
      "private": false,
      "scope": "audience_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "filename": {
      "tags": [],
      "default": "",
      "description": "Prefix to append to the name of the uploaded file. A lower cased audience name and timestamp will be appended by default to the filename to ensure uniqueness.\n                    Format: <PREFIX>_<AUDIENCE NAME>_<TIMESTAMP>.csv",
      "encrypt": false,
      "hidden": false,
      "label": "Filename prefix",
      "private": false,
      "scope": "audience_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "delimiter": {
      "tags": [],
