    "iam_role_arn",
    "s3_aws_bucket_name",
    "s3_aws_region",
    "iam_external_id",
    "s3_aws_folder_name",
    "filename",
    "delimiter",
    "__segment_internal_engage_batch_sync",
    "__segment_internal_engage_support_audience_functions"
  ],
  "options": {
    "iam_role_arn": {
      "tags": ["authentication:test"],
      "default": "",
