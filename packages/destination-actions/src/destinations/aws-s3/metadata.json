        "required": true,
        "choices": null,
        "default": null
      },
      "s3_aws_bucket_name": {
        "label": "AWS Bucket Name",
        "description": "Name of the S3 bucket where the files will be uploaded to.",
        "type": "string",
        "required": true,
        "choices": null,
        "default": null
      },
      "s3_aws_region": {
        "label": "AWS Region Code (S3 only)",
