  "presets": [
    {
      "name": "Track Calls",
      "type": "automatic",
      "partnerAction": "receiveEvents",
      "subscribe": "type = \"track\"",
      "mapping": {
        "email": {
          "@if": {
            "exists": {
              "@path": "$.properties.email"
            },
            "then": {
              "@path": "$.properties.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
          "@path": "$.timestamp"
        }
      },
      "eventSlug": null
    },
    {
      "name": "Identify Calls",
      "type": "automatic",
      "partnerAction": "receiveEvents",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "email": {
          "@if": {
            "exists": {
              "@path": "$.traits.email"
            },
            "then": {
              "@path": "$.traits.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
