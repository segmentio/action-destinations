        "label": "Region",
        "description": "Region for API Endpoint, either US, EU, AP, or CA",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": [
          {
            "label": "US",
            "value": "US"
          },
          {
            "label": "EU",
            "value": "EU"
          },
          {
            "label": "AP",
            "value": "AP"
          },
          {
            "label": "CA",
            "value": "CA"
