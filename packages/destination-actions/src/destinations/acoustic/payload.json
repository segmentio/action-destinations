  "presets": [
    {
      "partnerAction": "receiveEvents",
      "name": "Identify Calls",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "email": {
          "@if": {
            "exists": {
              "@path": "$.traits.email"
            },
            "then": {
              "@path": "$.traits.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
          "@path": "$.timestamp"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "receiveEvents",
      "name": "Track Calls",
      "subscribe": "type = \"track\"",
      "mapping": {
        "email": {
          "@if": {
            "exists": {
              "@path": "$.properties.email"
            },
            "then": {
              "@path": "$.properties.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "type": {
          "@path": "$.type"
        },
        "timestamp": {
          "@path": "$.timestamp"
        }
      },
      "type": "automatic"
    }
