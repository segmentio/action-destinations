    {
      "slug": "trackEvent",
      "name": "Track Event",
      "description": "Send a Segment track event to Optimizely",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\"",
      "fields": [
        {
          "fieldKey": "uuid",
          "type": "string",
          "label": "UUID",
          "description": "Unique message UUID to send with the event",
          "defaultValue": {
            "@path": "$.messageId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "uuid": {
                "title": "UUID",
                "description": "Unique message UUID to send with the event",
                "type": "string"
              }
            },
            "required": [
              "uuid"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "endUserId",
          "type": "string",
          "label": "Optimizely End User ID",
          "description": "The unique identifier for the user. The value should be taken from the optimizelyEndUserId cookie, or it can be collected using window.optimizely.get('visitor').visitorId. If using the BYOID feature pass in the value of the ID for your user.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties.end_user_id"
              },
              "then": {
                "@path": "$.properties.end_user_id"
              },
              "else": {
                "@path": "$.integrations.Optimizely Web (Actions).end_user_id"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "endUserId": {
                "title": "Optimizely End User ID",
                "description": "The unique identifier for the user. The value should be taken from the optimizelyEndUserId cookie, or it can be collected using window.optimizely.get('visitor').visitorId. If using the BYOID feature pass in the value of the ID for your user.",
                "type": "string"
              }
            },
            "required": [
              "endUserId"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "anonymizeIP",
          "type": "boolean",
          "label": "Anonymize IP",
          "description": "Anonymize the IP address of the user.",
          "defaultValue": true,
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "anonymizeIP": {
                "title": "Anonymize IP",
                "description": "Anonymize the IP address of the user.",
                "type": "boolean"
              }
            },
            "required": [
              "anonymizeIP"
            ]
          },
          "dependsOn": null,
          "displayMetadata": {
            "disabledInputMethods": [
              "enrichment",
              "freeform",
              "function",
              "literal",
              "variable"
            ]
          }
        },
        {
          "fieldKey": "eventSyncConfig",
          "type": "object",
          "label": "Event Syncing Configuration",
          "description": "Specify how Segment should sync Segment events to Optimizely events, as well as specify if Segment should create new Custom Events and Pages in Optimizely if they don't exist.",
          "defaultValue": {
            "createEventIfNotFound": "CREATE",
            "shouldSnakeCaseEventKey": false,
            "eventKey": {
              "@if": {
                "exists": {
                  "@path": "$.event"
                },
                "then": {
                  "@path": "$.event"
                },
                "else": {
                  "@path": "$.name"
                }
              }
            },
            "eventId": {
              "@path": "$.properties.event_id"
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "eventSyncConfig": {
                "title": "Event Syncing Configuration",
                "description": "Specify how Segment should sync Segment events to Optimizely events, as well as specify if Segment should create new Custom Events and Pages in Optimizely if they don't exist.",
                "type": "object",
                "$schema": "http://json-schema.org/schema#",
                "additionalProperties": false,
                "properties": {
                  "createEventIfNotFound": {
                    "title": "Create If Not Found",
                    "description": "Segment can define new Custom Events in Optimizely, along with their custom properties. However once an event is defined by Segment its properties cannot be modified.",
                    "type": "string",
                    "enum": [
                      "DO_NOT_CREATE",
                      "CREATE"
                    ]
                  },
                  "shouldSnakeCaseEventKey": {
                    "title": "Should Snake Case Event Key",
                    "description": "If the event key should be converted to snake case before sending to Optimizely.",
                    "type": "boolean"
                  },
                  "eventKey": {
                    "title": "Event Key",
                    "description": "Optimizely event or page key to record the event against.",
                    "type": "string",
                    "default": {
                      "@path": "$.event"
                    }
                  },
                  "eventId": {
                    "title": "Event ID",
                    "description": "Optimizely event or page ID to record the event against. The ID can only be used when the event / page has already been created in Optimizely. Segment cannot create new events in Optimizely using the ID.",
                    "type": "string"
                  }
                },
                "required": [
                  "createEventIfNotFound",
                  "shouldSnakeCaseEventKey"
                ]
              }
            },
            "required": [
              "eventSyncConfig"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
