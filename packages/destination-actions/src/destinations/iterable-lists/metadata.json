          "disabledInputMethods": null,
          "displayMode": null,
          "format": null,
          "additionalProperties": false
        },
        "traitsOrProperties": {
          "label": "Traits or Properties",
          "description": "Traits or Properties object from the identify() or track() call emitted by Engage",
          "type": "object",
          "required": true,
          "multiple": false,
          "allowNull": false,
          "dynamic": false,
          "default": {
            "@if": {
              "exists": {
                "@path": "$.traits"
              },
              "then": {
                "@path": "$.traits"
              },
              "else": {
                "@path": "$.properties"
              }
            }
          },
          "choices": null,
          "placeholder": null,
          "properties": null,
          "category": null,
          "depends_on": null,
          "readOnly": null,
          "hidden": true,
          "minimum": null,
