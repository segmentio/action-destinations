{
  "name": "Optimizely Advanced Audience Targeting",
  "description": "Sync Segment Engage Audiences to Optimizely Data Platform",
  "basicOptions": [
    "apiKey",
    "region"
  ],
  "options": {
    "apiKey": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Api Key used for Optimizely API authorization when sending events",
      "encrypt": true,
      "hidden": false,
      "label": "Api Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The apiKey property is required."
        ]
      ],
      "uIMetadata": null
    },
    "region": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "The Optimizely Region to sync Audience data to. Default is US",
      "encrypt": false,
      "hidden": false,
      "label": "Region",
      "private": true,
      "scope": "event_destination",
      "type": "select",
      "options": [
        {
          "value": "US",
          "label": "US",
          "text": "US"
        },
        {
          "value": "EU",
          "label": "Europe",
          "text": "Europe"
        },
        {
          "value": "AU",
          "label": "Australia",
          "text": "Australia"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The region property is required."
        ]
      ],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync Audience",
      "description": "Sync a Segment Engage Audience to Optimizely Data Platform",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\" or type = \"identify\"",
      "fields": [
        {
          "fieldKey": "custom_audience_name",
          "type": "string",
          "label": "Custom Audience Name",
          "description": "Name of custom audience to add or remove the user from",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "custom_audience_name": {
                "title": "Custom Audience Name",
                "description": "Name of custom audience to add or remove the user from",
                "type": "string"
              }
            },
            "required": [
              "custom_audience_name"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "Audience",
              "value": "audience"
            },
            {
              "label": "journey_step",
              "value": "journey_step"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
                "type": "string",
                "enum": [
                  "audience",
                  "journey_step"
                ]
              }
            },
            "required": [
              "segment_computation_action"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_id",
          "type": "string",
          "label": "Segment Computation ID",
          "description": "Segment computation ID",
          "defaultValue": {
            "@path": "$.context.personas.computation_id"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_id": {
                "title": "Segment Computation ID",
                "description": "Segment computation ID",
                "type": "string"
              }
            },
            "required": [
              "segment_computation_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "optimizelyUserId",
          "type": "string",
          "label": "Optimizely User ID",
          "description": "The user identifier to sync to the Optimizely Audience",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.userId"
              },
              "then": {
                "@path": "$.userId"
              },
              "else": {
                "@path": "$.anonymousId"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "optimizelyUserId": {
                "title": "Optimizely User ID",
                "description": "The user identifier to sync to the Optimizely Audience",
                "type": "string"
              }
            },
            "required": [
              "optimizelyUserId"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "timestamp",
          "type": "string",
          "label": "Timestamp",
          "description": "Timestamp indicates when the user was added or removed from the Audience",
          "defaultValue": {
            "@path": "$.timestamp"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "timestamp": {
                "title": "Timestamp",
                "description": "Timestamp indicates when the user was added or removed from the Audience",
                "type": "string"
              }
            },
            "required": [
              "timestamp"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Enable Batching",
          "description": "Enable batching of event data to Optimizely.",
          "defaultValue": true,
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enable_batching": {
                "title": "Enable Batching",
                "description": "Enable batching of event data to Optimizely.",
                "type": "boolean"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "batch_size",
          "type": "integer",
          "label": "Batch Size",
          "description": "Number of events to batch before sending to Optimizely.",
          "defaultValue": 100,
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batch_size": {
                "title": "Batch Size",
                "description": "Number of events to batch before sending to Optimizely.",
                "type": "integer"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "batch_keys",
          "type": "string",
          "label": "Batch Keys",
          "description": "The keys to use for batching events.",
          "defaultValue": [
            "custom_audience_name"
          ],
          "required": false,
          "multiple": true,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batch_keys": {
                "title": "Batch Keys",
                "description": "The keys to use for batching events.",
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traitsOrProperties",
          "type": "object",
          "label": "Traits or Properties",
          "description": "User traits (for identify calls) or event properties (for track calls) to include with the audience sync.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits"
              },
              "then": {
                "@path": "$.traits"
              },
              "else": {
                "@path": "$.properties"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traitsOrProperties": {
                "title": "Traits or Properties",
                "description": "User traits (for identify calls) or event properties (for track calls) to include with the audience sync.",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": []
}
