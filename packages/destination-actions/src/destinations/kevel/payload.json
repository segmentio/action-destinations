{
  "name": "Kevel UserDB (Actions)",
  "description": "Send Segment user profiles and Audiences to Kevel UserDB for campaign targeting. Only users with a Segment userId will be synced.",
  "basicOptions": ["networkId", "apiKey"],
  "options": {
    "networkId": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Your Kevel Network ID",
      "encrypt": false,
      "hidden": false,
      "label": "Kevel Network ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The networkId property is required."]],
      "uIMetadata": null
    },
    "apiKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Your Kevel API Key",
      "encrypt": true,
      "hidden": false,
      "label": "Kevel API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The apiKey property is required."]],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": ["us-west-2", "eu-west-1"],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync Audience",
      "description": "Sync a Segment Engage Audience to a Kevel UserDB Interest. Only users with a Segment userId will be synced. See Kevel's [documentation for more details](https://dev.kevel.com/reference/add-interest-to-user).",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\" or type = \"identify\"",
      "fields": [
        {
          "fieldKey": "segment_computation_key",
          "type": "string",
          "label": "Audience Key",
          "description": "Segment Audience name to which user identifier should be added or removed",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_key": {
                "title": "Audience Key",
                "description": "Segment Audience name to which user identifier should be added or removed",
                "type": "string"
              }
            },
            "required": ["segment_computation_key"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "audience",
              "value": "audience"
            },
            {
              "label": "journey_step",
              "value": "journey_step"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
                "type": "string",
                "enum": ["audience", "journey_step"]
              }
            },
            "required": ["segment_computation_action"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_user_id",
          "type": "string",
          "label": "User ID",
          "description": "The user's unique ID",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_user_id": {
                "title": "User ID",
                "description": "The user's unique ID",
                "type": "string"
              }
            },
            "required": ["segment_user_id"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traits_or_props",
          "type": "object",
          "label": "Traits or properties object",
          "description": "A computed object for track and identify events. This field should not need to be edited.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties"
              },
              "then": {
                "@path": "$.properties"
              },
              "else": {
                "@path": "$.traits"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits_or_props": {
                "title": "Traits or properties object",
                "description": "A computed object for track and identify events. This field should not need to be edited.",
                "type": "object"
              }
            },
            "required": ["traits_or_props"]
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    },
    {
      "slug": "syncTraits",
      "name": "Sync Traits",
      "description": "Sync user profile traits and Audiences from Segment to Kevel UserDB as `customProperties`. See Kevel's [documentation for more details](https://dev.kevel.com/reference/set-custom-properties-alternative).",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\"",
      "fields": [
        {
          "fieldKey": "segment_user_id",
          "type": "string",
          "label": "User ID",
          "description": "The user's unique ID",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_user_id": {
                "title": "User ID",
                "description": "The user's unique ID",
                "type": "string"
              }
            },
            "required": ["segment_user_id"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traits",
          "type": "object",
          "label": "Traits",
          "description": "The user's profile traits / attributes",
          "defaultValue": {
            "@path": "$.traits"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits": {
                "title": "Traits",
                "description": "The user's profile traits / attributes",
                "type": "object"
              }
            },
            "required": ["traits"]
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": []
}
