                "type": "string"
              }
            },
            "required": ["object"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "matching_attribute",
          "type": "string",
          "label": "Matching Attribute",
          "description": "The Attribute (ID or slug) on the Attio Object above, that uniquely identifies a Record (and is marked as unique in Attio). Events containing the same value for this attribute will update the original Record, rather than creating a new one. For example, to create or update a Person you might use the Attio attribute `email_addresses` here.",
          "defaultValue": "email_addresses",
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "matching_attribute": {
                "title": "Matching Attribute",
