                "type": "string"
              }
            },
            "required": ["matching_attribute"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "attributes",
          "type": "object",
          "label": "Attributes",
          "description": "Attributes to either set or update on the Attio Record. The values on the left should be Segment attributes or custom text, and the values on the right are Attio Attribute IDs or Slugs, for example: traits.name → name. The Matching Attribute must be included for assertion to work.",
          "defaultValue": {},
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
