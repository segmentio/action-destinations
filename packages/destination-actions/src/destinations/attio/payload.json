{
  "name": "Attio (Actions)",
  "description": "The Attio destination allows you to assert Records in your Attio workspace based on Segment events",
  "basicOptions": ["required_hidden_token"],
  "options": {
    "required_hidden_token": {
      "label": "Required Hidden Token",
      "type": "string",
      "description": "This token is hidden because it is unused and destinations must have one setting.",
      "default": "",
      "private": true,
      "hidden": true,
      "scope": "event_destination"
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "oauth-managed",
  "supportedRegions": ["us-west-2", "eu-west-1"],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "assertRecord",
      "name": "Assert Record",
      "description": "Create or update a Record in Attio.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": null,
      "fields": [
        {
          "fieldKey": "object",
          "type": "string",
          "label": "Attio Object",
          "description": "The type of Attio Object you'd like to create or update ('assert')",
          "defaultValue": "person",
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": true,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "object": {
                "title": "Attio Object",
