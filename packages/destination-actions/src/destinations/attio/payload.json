  "presets": [
    {
      "partnerAction": "groupWorkspace",
      "name": "Group Workspace",
      "subscribe": "type = \"group\"",
      "mapping": {
        "domain": {
          "@if": {
            "exists": {
              "@path": "$.traits.website"
            },
            "then": {
              "@path": "$.traits.website"
            },
            "else": {
              "@path": "$.website"
            }
          }
        },
        "workspace_id": {
          "@if": {
            "exists": {
              "@path": "$.groupId"
            },
            "then": {
              "@path": "$.groupId"
            },
            "else": {
              "@path": "$.context.group_id"
            }
          }
        },
        "user_id": {
          "@path": "$.userId"
        },
        "company_attributes": {},
        "workspace_attributes": {},
        "enable_batching": false,
        "batch_size": 1000,
        "received_at": {
          "@path": "$.receivedAt"
        }
      },
      "type": "automatic"
    },
    {
