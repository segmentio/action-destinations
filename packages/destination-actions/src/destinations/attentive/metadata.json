                  "$schema": "http://json-schema.org/schema#",
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "productId": {
                      "title": "productId",
                      "description": "A unique identifier for the product (i.e. \"T-Shirt\").",
