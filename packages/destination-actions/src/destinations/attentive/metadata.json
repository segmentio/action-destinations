                    },
                    "value": {
                      "title": "value",
                      "description": "The price of the product.",
                      "type": "number"
                    },
                    "productImage": {
                      "title": "productImage",
                      "description": "A link to the image of the product. The image should not be larger than 500kb. This image will be used when sending MMS text messages.",
                      "type": "string",
                      "format": "uri"
                    },
                    "productUrl": {
                      "title": "productUrl",
                      "description": "The URL for the product.",
                      "type": "string",
                      "format": "uri"
                    },
                    "name": {
                      "title": "name",
                      "description": "The name of the product. This should be in a format that could be used directly in a message.",
                      "type": "string"
                    },
                    "currency": {
                      "title": "currency",
                      "description": "Default: \"USD\". The currency used for the price in ISO 4217 format.",
                      "type": "string"
                    },
                    "quantity": {
                      "title": "quantity",
                      "description": "The number of products.",
                      "type": "integer"
                    }
                  },
                  "required": [
                    "productId",
                    "productVariantId",
                    "value"
                  ]
                }
              }
            },
            "required": [
              "items"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
