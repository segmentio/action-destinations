  "presets": [
    {
      "name": "Subscribe User",
      "type": "automatic",
      "partnerAction": "subscribeUser",
      "subscribe": "type = \"track\" and event = \"User Subscribed\"",
      "mapping": {
        "userIdentifiers": {
          "phone": {
            "@if": {
              "exists": {
                "@path": "$.context.traits.phone"
              },
              "then": {
                "@path": "$.context.traits.phone"
              },
              "else": {
                "@path": "$.properties.phone"
              }
            }
          },
          "email": {
            "@if": {
              "exists": {
                "@path": "$.context.traits.email"
              },
              "then": {
                "@path": "$.context.traits.email"
              },
              "else": {
                "@path": "$.properties.email"
              }
            }
          },
          "clientUserId": {
            "@path": "$.userId"
          }
        },
        "occurredAt": {
          "@path": "$.timestamp"
        },
        "externalEventId": {
          "@path": "$.messageId"
        },
        "subscriptionType": "TRANSACTIONAL",
        "locale": {
          "@path": "$.context.locale"
        },
        "singleOptIn": false
      },
      "eventSlug": null
    },
