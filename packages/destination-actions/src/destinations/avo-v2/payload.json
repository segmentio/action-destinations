{
  "name": "Avo Inspector v2",
  "basicOptions": ["apiKey", "publicEncryptionKey", "env", "appVersionPropertyName"],
  "options": {
    "apiKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Avo Inspector API Key can be found in the Inspector setup page on your source in Avo.",
      "encrypt": false,
      "hidden": false,
      "label": "Avo Inspector API Key",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The apiKey property is required."]],
      "uIMetadata": null
    },
    "publicEncryptionKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Optional. Enables verification of the property values against your Tracking Plan (e.g. allowed values, min/max constraints). Values are end-to-end encrypted and Avo can not decrypt them. Read more: https://www.avo.app/docs/inspector/connect-inspector-to-segment#property-value-validation-optional",
      "encrypt": false,
      "hidden": false,
      "label": "Avo Inspector Public Encryption Key",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "env": {
      "tags": ["authentication:test"],
      "default": "prod",
      "description": "Avo Inspector Environment",
      "encrypt": false,
      "hidden": false,
      "label": "Environment",
      "private": true,
      "scope": "event_destination",
      "type": "select",
      "options": [
        {
          "value": "dev",
          "label": "dev",
          "text": "dev"
        },
        {
          "value": "staging",
          "label": "staging",
          "text": "staging"
        },
        {
          "value": "prod",
          "label": "prod",
          "text": "prod"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The env property is required."]],
      "uIMetadata": null
    },
    "appVersionPropertyName": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "If you send a custom event property on all events that contains the app version, please enter the name of that property here (e.g. “app_version”). If you do not have a custom event property for the app version, please leave this field empty.",
      "encrypt": false,
      "hidden": false,
      "label": "App Version Property",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    }
  },
