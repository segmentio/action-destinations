    "apiToken": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Token used to authorize sending data to the Destination platform",
      "encrypt": true,
      "hidden": false,
      "label": "REST API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The apiToken property is required."]],
      "uIMetadata": null
    },
    "projectKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "The unique project key identifying your project in the Destination platform",
      "encrypt": false,
      "hidden": false,
      "label": "Project Key",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The projectKey property is required."]],
      "uIMetadata": null
