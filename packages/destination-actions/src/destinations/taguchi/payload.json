                  },
                  "state": {
                    "title": "State",
                    "description": "State of the Subscriber.",
                    "type": "string"
                  },
                  "country": {
                    "title": "Country",
                    "description": "Country of the Subscriber.",
                    "type": "string"
                  },
                  "postcode": {
                    "title": "Postcode",
                    "description": "Postcode of the Subscriber.",
                    "type": "string"
                  },
                  "gender": {
                    "title": "Gender",
                    "description": "Gender of the Subscriber.",
                    "type": "string"
                  }
