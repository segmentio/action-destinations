                },
                "then": {
                  "@path": "$.traits.phone"
                },
                "else": {
                  "@path": "$.context.traits.phone"
                }
              }
            },
            "gender": {
              "@if": {
                "exists": {
                  "@path": "$.traits.gender"
                },
                "then": {
                  "@path": "$.traits.gender"
                },
                "else": {
                  "@path": "$.context.traits.gender"
                }
              }
