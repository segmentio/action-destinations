                  "@path": "$.context.traits.city"
                }
              }
            },
            "state": {
              "@if": {
                "exists": {
                  "@path": "$.traits.state"
                },
                "then": {
                  "@path": "$.traits.state"
                },
                "else": {
                  "@path": "$.context.traits.state"
                }
              }
            },
            "country": {
              "@if": {
                "exists": {
                  "@path": "$.traits.country"
                },
                "then": {
                  "@path": "$.traits.country"
                },
                "else": {
                  "@path": "$.context.traits.country"
                }
              }
            },
            "postcode": {
              "@if": {
