          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "traits": {
                "title": "Traits",
                "description": "Standard traits for the Subscriber. All text fields. No specific formats for any of them.",
                "type": "object",
                "$schema": "http://json-schema.org/schema#",
                "additionalProperties": true,
                "properties": {
                  "title": {
                    "title": "Title",
                    "description": "Title of the Subscriber.",
