    {
      "partnerAction": "trackEvent",
      "name": "Page Calls",
      "subscribe": "type = \"page\"",
      "mapping": {
        "event": {
          "@template": "Viewed {{name}}"
        },
        "userId": {
          "@path": "$.userId"
        },
        "anonymousId": {
          "@path": "$.anonymousId"
        },
        "groupId": {
          "@path": "$.context.groupId"
        },
        "messageId": {
          "@path": "$.messageId"
        },
        "timestamp": {
          "@path": "$.timestamp"
        },
        "properties": {
          "@path": "$.properties"
        },
        "traits": {
          "@if": {
            "exists": {
              "@path": "$.traits"
            },
            "then": {
              "@path": "$.traits"
            },
            "else": {
              "@path": "$.context.traits"
            }
          }
        },
        "context": {
          "@path": "$.context"
        },
        "enable_batching": true
      },
      "type": "automatic"
    },
