    {
      "partnerAction": "groupIdentifyUser",
      "name": "Group Calls",
      "subscribe": "type = \"group\"",
      "mapping": {
        "groupId": {
          "@path": "$.groupId"
        },
        "traits": {
          "@path": "$.traits"
