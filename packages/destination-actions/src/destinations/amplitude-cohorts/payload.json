{
  "name": "Amplitude Cohorts",
  "description": "Sync Segment Engage audiences to Amplitude Cohorts",
  "basicOptions": [
    "api_key",
    "secret_key",
    "app_id",
    "default_owner_email",
    "endpoint",
    "owner_email",
    "id_type",
    "audience_name",
    "__segment_internal_engage_batch_sync",
    "__segment_internal_engage_support_audience_functions"
  ],
  "options": {
    "api_key": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Amplitude project API key. You can find this key in the \"General\" tab of your Amplitude project.",
      "encrypt": true,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The api_key property is required."]],
      "uIMetadata": null
    },
    "secret_key": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Amplitude project secret key. You can find this key in the \"General\" tab of your Amplitude project.",
      "encrypt": true,
      "hidden": false,
      "label": "Secret Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The secret_key property is required."]],
      "uIMetadata": null
    },
    "app_id": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "The Amplitude App ID for the cohort you want to sync to. You can find this in the \"General\" tab of your Amplitude project.",
      "encrypt": false,
      "hidden": false,
      "label": "Amplitude App ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The app_id property is required."]],
      "uIMetadata": null
    },
    "default_owner_email": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "The email of the user who will own the cohorts in Amplitude. This can be overriden per Audience, but if left blank, all cohorts will be owned by this user.",
      "encrypt": false,
      "hidden": false,
      "label": "Cohort Owner Email",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The default_owner_email property is required."]],
      "uIMetadata": null
    },
    "endpoint": {
      "tags": ["authentication:test"],
      "default": "north_america",
      "description": "The region to send your data.",
      "encrypt": false,
      "hidden": false,
      "label": "Endpoint Region",
      "private": true,
      "scope": "event_destination",
      "type": "select",
      "options": [
        {
          "value": "north_america",
          "label": "North America",
          "text": "North America"
        },
        {
          "value": "europe",
          "label": "Europe",
          "text": "Europe"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The endpoint property is required."]],
      "uIMetadata": null
    },
    "owner_email": {
      "tags": [],
      "default": "",
      "description": "The email of the user who will own the cohort in Amplitude. Overrides the default Cohort Owner Email value from Settings.",
      "encrypt": false,
      "hidden": false,
      "label": "Cohort Owner Email",
      "private": false,
      "scope": "audience_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "id_type": {
      "tags": [],
      "default": "BY_USER_ID",
      "description": "The type of ID that will be used to sync users to the Amplitude Cohort.",
      "encrypt": false,
      "hidden": false,
      "label": "ID Type",
      "private": false,
      "scope": "audience_destination",
      "type": "select",
      "options": [
        {
          "value": "BY_USER_ID",
          "label": "User ID",
          "text": "User ID"
        },
        {
          "value": "BY_AMP_ID",
          "label": "Amplitude ID",
          "text": "Amplitude ID"
        }
      ],
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The id_type property is required."]],
      "uIMetadata": null
    },
    "audience_name": {
      "tags": [],
      "default": "",
      "description": "The name of the cohort in Amplitude. This will override the default cohort name which is the snake_case version of the Segment Audience name.",
      "encrypt": false,
      "hidden": false,
      "label": "Cohort Name",
      "private": false,
      "scope": "audience_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "__segment_internal_engage_batch_sync": {
      "private": true,
      "hidden": true,
      "encrypt": false,
      "readOnly": true,
      "validators": [],
      "label": "Indicates that this is a batched (or synced) destination on some schedule",
      "type": "boolean",
      "description": "Indicates that this is a batched (or synced) destination on some schedule",
      "default": true,
      "scope": "event_destination"
    },
    "__segment_internal_engage_support_audience_functions": {
      "private": true,
      "hidden": true,
      "encrypt": false,
      "readOnly": true,
      "validators": [],
      "label": "Supports Audience Functions (getAudience/createAudience)",
      "type": "boolean",
      "description": "Supports Audience Functions (getAudience/createAudience)",
      "default": true,
      "scope": "event_destination"
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": ["us-west-2", "eu-west-1"],
  "supportsAudiences": true,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync To Amplitude Cohort",
      "description": "Sync Segment Audience to Amplitude Cohort",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\" or type = \"track\"",
      "fields": [
        {
          "fieldKey": "user_id",
          "type": "string",
          "label": "User ID",
          "description": "Required if \"ID Type\" is set to \"User ID\".",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "user_id": {
                "title": "User ID",
                "description": "Required if \"ID Type\" is set to \"User ID\".",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "amplitude_id",
          "type": "string",
          "label": "Amplitude ID",
          "description": "Required if \"ID Type\" is set to \"Amplitude ID\".",
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "amplitude_id": {
                "title": "Amplitude ID",
                "description": "Required if \"ID Type\" is set to \"Amplitude ID\".",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_external_audience_id",
          "type": "string",
          "label": "Segment External Audience ID",
          "description": "Hidden field containing the Cohort ID which was returned when the Amplitude Cohort was created in the Audience Settings.",
          "defaultValue": {
            "@path": "$.context.personas.external_audience_id"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_external_audience_id": {
                "title": "Segment External Audience ID",
                "description": "Hidden field containing the Cohort ID which was returned when the Amplitude Cohort was created in the Audience Settings.",
                "type": "string"
              }
            },
            "required": ["segment_external_audience_id"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "batch_size",
          "type": "number",
          "label": "Max Batch Size",
          "description": "The maximum number of users to process in a single batch request.",
          "defaultValue": 100,
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batch_size": {
                "title": "Max Batch Size",
                "description": "The maximum number of users to process in a single batch request.",
                "type": "number",
                "minimum": 1,
                "maximum": 500
              }
            },
            "required": ["batch_size"]
          },
          "dependsOn": null,
          "minimum": 1,
          "maximum": 500,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Enable Batching?",
          "description": "When enabled, Segment will send events in batches.",
          "defaultValue": false,
          "required": false,
          "multiple": false,
          "dynamic": false,
          "allowNull": false,
          "choices": null
        }
      ]
    }
  ],
  "presets": [
    {
      "partnerAction": "syncAudience",
      "name": "Associated Entity Added",
      "mapping": {
        "user_id": {
          "@path": "$.userId"
        },
        "segment_external_audience_id": {
          "@path": "$.context.personas.external_audience_id"
        },
        "batch_size": 100
      },
      "type": "specificEvent",
      "eventSlug": "warehouse_entity_added_track"
    },
    {
      "partnerAction": "syncAudience",
      "name": "Associated Entity Removed",
      "mapping": {
        "user_id": {
          "@path": "$.userId"
        },
        "segment_external_audience_id": {
          "@path": "$.context.personas.external_audience_id"
        },
        "batch_size": 100
      },
      "type": "specificEvent",
      "eventSlug": "warehouse_entity_removed_track"
    },
    {
      "partnerAction": "syncAudience",
      "name": "Entities Audience Membership Changed",
      "mapping": {
        "user_id": {
          "@path": "$.userId"
        },
        "segment_external_audience_id": {
          "@path": "$.context.personas.external_audience_id"
        },
        "batch_size": 100
      },
      "type": "specificEvent",
      "eventSlug": "warehouse_audience_membership_changed_identify"
    },
    {
      "partnerAction": "syncAudience",
      "name": "Journeys Step Entered",
      "mapping": {
        "user_id": {
          "@path": "$.userId"
        },
        "segment_external_audience_id": {
          "@path": "$.context.personas.external_audience_id"
        },
        "batch_size": 100
      },
      "type": "specificEvent",
      "eventSlug": "journeys_step_entered_track"
    }
  ]
}
