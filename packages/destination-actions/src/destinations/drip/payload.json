{
  "name": "Drip (Actions)",
  "description": "Send Segment analytics events and user profile details to Drip",
  "basicOptions": ["accountId", "apiKey"],
  "options": {
    "accountId": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Account ID for your Drip account. You can find this in your Drip account settings.",
      "encrypt": false,
      "hidden": false,
      "label": "Account ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The accountId property is required."]],
      "uIMetadata": null
    },
    "apiKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "API key for your Drip account. You can find this in your Drip account settings.",
      "encrypt": true,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The apiKey property is required."]],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": ["us-west-2", "eu-west-1"],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "identify",
      "name": "Identify",
      "description": "Identify person in Drip",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\"",
      "fields": [
        {
          "fieldKey": "custom_fields",
          "type": "object",
          "label": "Custom fields",
          "description": "Custom fields to add to a person's profile. Non string values will be stringified.",
          "defaultValue": {
            "@path": "$.traits.custom_fields"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "custom_fields": {
                "title": "Custom fields",
                "description": "Custom fields to add to a person's profile. Non string values will be stringified.",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "email",
          "type": "string",
          "label": "Email Address",
          "description": "The person's email address.",
          "defaultValue": {
            "@path": "$.traits.email"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email": {
                "title": "Email Address",
                "description": "The person's email address.",
                "type": "string",
                "format": "email"
              }
            },
            "required": ["email"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "ip",
          "type": "string",
          "label": "IP Address",
          "description": "The person's ip address.",
          "defaultValue": {
            "@path": "$.context.ip"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ip": {
                "title": "IP Address",
                "description": "The person's ip address.",
                "type": "string",
                "format": "ipv4"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "phone",
          "type": "string",
          "label": "SMS Number",
          "description": "The person's sms number.",
          "defaultValue": {
            "@path": "$.traits.phone"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "phone": {
                "title": "SMS Number",
                "description": "The person's sms number.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "initial_status",
          "type": "string",
          "label": "Initial Status",
          "description": "The person's subscription status if newly identified.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.initial_status"
              },
              "then": {
                "@path": "$.traits.initial_status"
              },
              "else": "unsubscribed"
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "initial_status": {
                "title": "Initial Status",
                "description": "The person's subscription status if newly identified.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "status",
          "type": "string",
          "label": "Status",
          "description": "The person's subscription status. Overrides initial_status.",
          "defaultValue": {
            "@path": "$.traits.status"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "status": {
                "title": "Status",
                "description": "The person's subscription status. Overrides initial_status.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "status_updated_at",
          "type": "datetime",
          "label": "Status Updated At",
          "description": "The timestamp associated with the update to a person's status.",
          "defaultValue": {
            "@path": "$.traits.status_updated_at"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "status_updated_at": {
                "title": "Status Updated At",
                "description": "The timestamp associated with the update to a person's status.",
                "type": ["string", "number"],
                "format": "date-like"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "tags",
          "type": "string",
          "label": "Tags",
          "description": "Comma delimited list of tags to add to a person's profile. e.g. \"tag1,tag2\".",
          "defaultValue": {
            "@path": "$.traits.tags"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tags": {
                "title": "Tags",
                "description": "Comma delimited list of tags to add to a person's profile. e.g. \"tag1,tag2\".",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "timezone",
          "type": "string",
          "label": "Timezone",
          "description": "The person's timezone.",
          "defaultValue": {
            "@path": "$.context.timezone"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "timezone": {
                "title": "Timezone",
                "description": "The person's timezone.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "batch_size",
          "type": "integer",
          "label": "Batch Size",
          "description": "Maximum number of events to include in each batch. Actual batch sizes may be lower. Max size must be between 1 and 1000 inclusive.",
          "defaultValue": 1000,
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batch_size": {
                "title": "Batch Size",
                "description": "Maximum number of events to include in each batch. Actual batch sizes may be lower. Max size must be between 1 and 1000 inclusive.",
                "type": "integer"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "minimum": 1,
          "maximum": 1000,
          "displayMetadata": {
            "disabledInputMethods": ["variable", "function", "enrichment"]
          }
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Enable Batching?",
          "description": "When enabled, Segment will send events in batches.",
          "defaultValue": false,
          "required": false,
          "multiple": false,
          "dynamic": false,
          "allowNull": false,
          "choices": null
        }
      ]
    },
    {
      "slug": "trackEvent",
      "name": "Track Event",
      "description": "Send track() events to Drip",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"track\"",
      "fields": [
        {
          "fieldKey": "action",
          "type": "string",
          "label": "Action",
          "description": "The name of the action.",
          "defaultValue": {
            "@path": "$.event"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "action": {
                "title": "Action",
                "description": "The name of the action.",
                "type": "string"
              }
            },
            "required": ["action"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "email",
          "type": "string",
          "label": "Email Address",
          "description": "The person's email address.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties.email"
              },
              "then": {
                "@path": "$.properties.email"
              },
              "else": {
                "@path": "$.context.traits.email"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email": {
                "title": "Email Address",
                "description": "The person's email address.",
                "type": "string",
                "format": "email"
              }
            },
            "required": ["email"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "properties",
          "type": "object",
          "label": "Properties",
          "description": "Additional properties associated with the event.",
          "defaultValue": {
            "@path": "$.properties"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "properties": {
                "title": "Properties",
                "description": "Additional properties associated with the event.",
                "type": "object"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": [
    {
      "partnerAction": "identify",
      "name": "Identify",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "custom_fields": {
          "@path": "$.traits.custom_fields"
        },
        "email": {
          "@path": "$.traits.email"
        },
        "ip": {
          "@path": "$.context.ip"
        },
        "phone": {
          "@path": "$.traits.phone"
        },
        "initial_status": {
          "@if": {
            "exists": {
              "@path": "$.traits.initial_status"
            },
            "then": {
              "@path": "$.traits.initial_status"
            },
            "else": "unsubscribed"
          }
        },
        "status": {
          "@path": "$.traits.status"
        },
        "status_updated_at": {
          "@path": "$.traits.status_updated_at"
        },
        "tags": {
          "@path": "$.traits.tags"
        },
        "timezone": {
          "@path": "$.context.timezone"
        },
        "batch_size": 1000
      },
      "type": "automatic"
    },
    {
      "partnerAction": "trackEvent",
      "name": "Track event",
      "subscribe": "type = \"track\"",
      "mapping": {
        "action": {
          "@path": "$.event"
        },
        "email": {
          "@if": {
            "exists": {
              "@path": "$.properties.email"
            },
            "then": {
              "@path": "$.properties.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "properties": {
          "@path": "$.properties"
        }
      },
      "type": "automatic"
    }
  ]
}
