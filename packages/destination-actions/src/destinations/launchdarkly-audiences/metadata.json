{
  "name": "LaunchDarkly Audiences",
  "description": "Sync [Segment Audiences](https://segment.com/docs/engage/audiences/) to LaunchDarkly [Big Segments](https://docs.launchdarkly.com/home/contexts/big-segments).",
  "basicOptions": [
    "apiKey",
    "clientId"
  ],
  "options": {
    "apiKey": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "We recommend creating a dedicated [LaunchDarkly service token](https://docs.launchdarkly.com/home/account-security/api-access-tokens#service-tokens) for this destination. The service token must have the ability to perform the `createSegment` and `updateIncluded` [role actions](https://docs.launchdarkly.com/home/members/role-actions#segment-actions).",
      "encrypt": true,
      "hidden": false,
      "label": "LaunchDarkly Service Token",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The apiKey property is required."
        ]
      ],
      "uIMetadata": null
    },
    "clientId": {
      "tags": [
        "authentication:test"
      ],
      "default": "",
      "description": "Copy the [client-side ID](https://app.launchdarkly.com/settings/projects) of the environment for your segment. You can find this in the LaunchDarkly **Account settings** page for your project.",
      "encrypt": false,
      "hidden": false,
      "label": "LaunchDarkly client-side ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The clientId property is required."
        ]
      ],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": true,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "authenticationScheme": "custom",
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
    {
      "slug": "syncAudience",
      "name": "Sync Audience",
      "description": "Sync Engage Audiences to LaunchDarkly segments",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\" or type = \"track\"",
      "fields": [
        {
          "fieldKey": "segment_audience_id",
          "type": "string",
          "label": "Audience ID",
          "description": "Segment Audience ID to which user identifier should be added or removed",
          "defaultValue": {
            "@path": "$.context.personas.computation_id"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_audience_id": {
                "title": "Audience ID",
                "description": "Segment Audience ID to which user identifier should be added or removed",
                "type": "string"
              }
            },
            "required": [
              "segment_audience_id"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_audience_key",
          "type": "string",
          "label": "Audience Key",
          "description": "Segment Audience key to which user identifier should be added or removed",
          "defaultValue": {
            "@path": "$.context.personas.computation_key"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_audience_key": {
                "title": "Audience Key",
                "description": "Segment Audience key to which user identifier should be added or removed",
                "type": "string"
              }
            },
            "required": [
              "segment_audience_key"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_computation_action",
          "type": "string",
          "label": "Segment Computation Action",
          "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
          "defaultValue": {
            "@path": "$.context.personas.computation_class"
          },
          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "audience",
              "value": "audience"
            },
            {
              "label": "journey_step",
              "value": "journey_step"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_computation_action": {
                "title": "Segment Computation Action",
                "description": "Hidden field used to verify that the payload is generated by an Audience. Payloads not containing computation_class = 'audience' or 'journey_step' will be dropped before the perform() fuction call.",
                "type": "string",
                "enum": [
                  "audience",
                  "journey_step"
                ]
              }
            },
            "required": [
              "segment_computation_action"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "context_kind",
          "type": "string",
          "label": "Context kind",
          "description": "The event's context kind. To learn more about context kinds and where you can find a list of context kinds LaunchDarkly has observed, read [Context kinds](https://docs.launchdarkly.com/home/contexts/context-kinds).",
          "defaultValue": "user",
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "context_kind": {
                "title": "Context kind",
                "description": "The event's context kind. To learn more about context kinds and where you can find a list of context kinds LaunchDarkly has observed, read [Context kinds](https://docs.launchdarkly.com/home/contexts/context-kinds).",
                "type": "string"
              }
            },
            "required": [
              "context_kind"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_user_id",
          "type": "string",
          "label": "Segment User ID",
          "description": "The Segment userId value.",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_user_id": {
                "title": "Segment User ID",
                "description": "The Segment userId value.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "segment_anonymous_id",
          "type": "string",
          "label": "Segment Anonymous ID",
          "description": "The Segment anonymousId value.",
          "defaultValue": {
            "@path": "$.anonymousId"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "segment_anonymous_id": {
                "title": "Segment Anonymous ID",
                "description": "The Segment anonymousId value.",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "user_email",
          "type": "string",
          "label": "Email address",
          "description": "The user's email address",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.email"
              },
              "then": {
                "@path": "$.traits.email"
              },
              "else": {
                "@path": "$.context.traits.email"
              }
            }
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "user_email": {
                "title": "Email address",
                "description": "The user's email address",
                "type": "string"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "context_key",
          "type": "string",
          "label": "Context key",
          "description": "The unique LaunchDarkly context key. In most cases the Segment UserId should be used.",
          "defaultValue": "user_id_only",
          "required": true,
          "multiple": false,
          "choices": [
            {
              "value": "user_id_then_email",
              "label": "Use Segment UserId or email"
            },
            {
              "value": "user_id_then_anonymousId",
              "label": "Use Segment UserId or Segment AnonymousId"
            },
            {
              "value": "user_id_then_email_then_anonymousId",
              "label": "Use Segment UserId or email or Segment AnonymousId"
            },
            {
              "value": "user_id_only",
              "label": "Use Segment UserId only"
            },
            {
              "value": "email_only",
              "label": "Use email only"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "context_key": {
                "title": "Context key",
                "description": "The unique LaunchDarkly context key. In most cases the Segment UserId should be used.",
                "type": "string",
                "enum": [
                  "user_id_then_email",
                  "user_id_then_anonymousId",
                  "user_id_then_email_then_anonymousId",
                  "user_id_only",
                  "email_only"
                ]
              }
            },
            "required": [
              "context_key"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "traits_or_props",
          "type": "object",
          "label": "Traits or properties object",
          "description": "A computed object for track and identify events. This field should not need to be edited.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.properties"
              },
              "then": {
                "@path": "$.properties"
              },
              "else": {
                "@path": "$.traits"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "traits_or_props": {
                "title": "Traits or properties object",
                "description": "A computed object for track and identify events. This field should not need to be edited.",
                "type": "object"
              }
            },
            "required": [
              "traits_or_props"
            ]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "enable_batching",
          "type": "boolean",
          "label": "Batch events",
          "description": "When enabled, the action will batch events before sending them to LaunchDarkly. In most cases, batching should be enabled.",
          "defaultValue": true,
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enable_batching": {
                "title": "Batch events",
                "description": "When enabled, the action will batch events before sending them to LaunchDarkly. In most cases, batching should be enabled.",
                "type": "boolean"
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "audience_action",
          "type": "string",
          "label": "Audience Action",
          "description": "Indicates if the user will be added or removed from the Audience",
          "required": false,
          "multiple": false,
          "choices": [
            {
              "label": "ADD",
              "value": "ADD"
            },
            {
              "label": "REMOVE",
              "value": "REMOVE"
            }
          ],
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "hidden": true,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "audience_action": {
                "title": "Audience Action",
                "description": "Indicates if the user will be added or removed from the Audience",
                "type": "string",
                "enum": [
                  "ADD",
                  "REMOVE"
                ]
              }
            },
            "required": []
          },
          "dependsOn": null,
          "displayMetadata": null
        }
      ]
    }
  ],
  "presets": [
    {
      "partnerAction": "syncAudience",
      "name": "Sync Engage Audience to LaunchDarkly",
      "subscribe": "type = \"identify\" or type = \"track\"",
      "mapping": {
        "segment_audience_id": {
          "@path": "$.context.personas.computation_id"
        },
        "segment_audience_key": {
          "@path": "$.context.personas.computation_key"
        },
        "segment_computation_action": {
          "@path": "$.context.personas.computation_class"
        },
        "context_kind": "user",
        "segment_user_id": {
          "@path": "$.userId"
        },
        "segment_anonymous_id": {
          "@path": "$.anonymousId"
        },
        "user_email": {
          "@if": {
            "exists": {
              "@path": "$.traits.email"
            },
            "then": {
              "@path": "$.traits.email"
            },
            "else": {
              "@path": "$.context.traits.email"
            }
          }
        },
        "context_key": "user_id_only",
        "traits_or_props": {
          "@if": {
            "exists": {
              "@path": "$.properties"
            },
            "then": {
              "@path": "$.properties"
            },
            "else": {
              "@path": "$.traits"
            }
          }
        },
        "enable_batching": true
      },
      "type": "automatic"
    }
  ]
}
