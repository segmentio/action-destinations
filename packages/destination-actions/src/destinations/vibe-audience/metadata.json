              },
              "else": {
                "@path": "$.properties.phone"
              }
            }
          }
        },
        "enable_batching": true,
        "batch_size": 1000,
        "batch_keys": [
          "audience_id",
          "audience_name"
        ]
      },
      "type": "automatic"
