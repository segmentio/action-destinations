  "presets": [
    {
      "partnerAction": "identifyUser",
      "name": "Identify User",
      "subscribe": "type = \"identify\"",
      "mapping": {
        "userId": {
          "@path": "$.userId"
        },
        "attributes": {
          "@path": "$.traits"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "trackEvent",
      "name": "Screen Event",
      "subscribe": "type = \"screen\"",
      "mapping": {
        "eventName": {
          "@path": "$.name"
        },
        "timestamp": {
          "@path": "$.timestamp"
        },
        "userId": {
          "@path": "$.userId"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "trackEvent",
      "name": "Track Event",
      "subscribe": "type = \"track\"",
      "mapping": {
        "eventName": {
          "@path": "$.event"
        },
        "timestamp": {
          "@path": "$.timestamp"
        },
        "userId": {
          "@path": "$.userId"
        }
      },
      "type": "automatic"
    }
  ]
}
