          "label": "User ID",
          "description": "The userId of the identified user.",
          "defaultValue": {
            "@path": "$.userId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "userId": {
                "title": "User ID",
                "description": "The userId of the identified user.",
                "type": "string"
              }
            },
            "required": ["userId"]
          },
          "dependsOn": null,
          "displayMetadata": null
