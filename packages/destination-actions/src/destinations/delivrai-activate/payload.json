    "client_identifier_id": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Client Identifier is the Hashed Key that provided by Delivr AI.",
      "encrypt": false,
      "hidden": false,
      "label": "Client Identifier",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The client_identifier_id property is required."]],
      "uIMetadata": null
    },
    "placeholder": {
      "tags": [],
      "default": true,
      "description": "Placeholder field to allow the audience to be created. Do not change this.",
      "encrypt": false,
      "hidden": false,
      "label": "Placeholder Setting",
      "private": false,
      "scope": "audience_destination",
      "type": "boolean",
      "readOnly": false,
      "dependsOn": null,
      "validators": [],
      "uIMetadata": null
    },
    "__segment_internal_engage_batch_sync": {
      "private": true,
      "hidden": true,
      "encrypt": false,
      "readOnly": true,
      "validators": [],
      "label": "Indicates that this is a batched (or synced) destination on some schedule",
      "type": "boolean",
      "description": "Indicates that this is a batched (or synced) destination on some schedule",
      "default": true,
      "scope": "event_destination"
    }
  },
  "platforms": {
