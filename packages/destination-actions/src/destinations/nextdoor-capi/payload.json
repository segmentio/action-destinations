      "description": "Enriches Segment payloads the Nextdoor Click ID",
      "platform": "web",
      "hidden": false,
      "defaultTrigger": "type = \"track\" or type = \"identify\" or type = \"page\" or type = \"group\" or type = \"alias\"",
      "fields": []
