          "required": true,
          "multiple": false,
          "choices": [
            {
              "label": "email",
              "value": "email"
            },
            {
              "label": "website",
              "value": "website"
            },
            {
              "label": "app",
              "value": "app"
            },
            {
              "label": "phone_call",
              "value": "phone_call"
            },
            {
              "label": "chat",
              "value": "chat"
            },
            {
              "label": "physical_store",
              "value": "physical_store"
            },
            {
              "label": "system_generated",
              "value": "system_generated"
            },
            {
              "label": "other",
              "value": "custom_conversion_8"
            }
