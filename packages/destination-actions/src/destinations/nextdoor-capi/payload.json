          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "action_source": {
                "title": "Action Source",
                "description": "Indicates the channel through which conversion happened.",
                "type": "string",
                "enum": [
                  "email",
                  "website",
                  "app",
                  "phone_call",
                  "chat",
                  "physical_store",
                  "system_generated",
                  "custom_conversion_8"
                ]
              }
            },
            "required": ["action_source"]
          },
          "dependsOn": null,
          "displayMetadata": null
        },
        {
          "fieldKey": "action_source_url",
          "type": "string",
          "label": "Action Source url",
          "description": "The browser URL where the event happened (required for web events).",
          "defaultValue": {
            "@path": "$.context.page.url"
          },
          "required": false,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "action_source_url": {
                "title": "Action Source url",
                "description": "The browser URL where the event happened (required for web events).",
                "type": "string"
              }
            },
            "required": [],
            "allOf": [
              {
                "if": {
                  "required": ["action_source"],
                  "properties": {
                    "action_source": {
                      "const": "website"
                    }
                  }
                },
                "then": {
                  "required": ["action_source_url"]
                }
              }
            ]
          },
          "dependsOn": null,
          "displayMetadata": {
            "conditionallyRequired": {
              "conditions": [
                {
                  "fieldKey": "action_source",
                  "operator": "is",
                  "value": "website"
                }
              ]
            }
          }
        },
        {
