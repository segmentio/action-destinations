    "apiKey": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "The Embed API Key for your account. You can find this on your settings pages.",
      "encrypt": true,
      "hidden": false,
      "label": "API Key",
      "private": true,
      "scope": "event_destination",
      "type": "password",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The apiKey property is required."]],
      "uIMetadata": null
    },
    "client_id": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Your Nextdoor Advertiser ID for self serve clients can be found in your NAM account for managed your support team can provide",
      "encrypt": false,
      "hidden": false,
      "label": "Nextdoor Advertiser ID",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The client_id property is required."]],
      "uIMetadata": null
    },
    "pixel_id": {
      "tags": ["authentication:test"],
      "default": "",
      "description": "Nextdoor Pixel Id. Used for deduplication when events are sent via CAPI and front end Pixel.",
      "encrypt": false,
      "hidden": false,
      "label": "Nextdoor Pixel Id",
      "private": true,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The pixel_id property is required."]],
      "uIMetadata": null
    }
  },
  "platforms": {
