          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "event_time": {
                "title": "Event Time",
                "description": "UCT Timestamp with ISO 8601 format. For example, 2022-11-23T03:30:52Z",
                "type": "string"
              }
            },
