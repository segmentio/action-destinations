    {
      "slug": "prospects",
      "name": "Upsert Prospect",
      "description": "Create or update a prospect in Pardot using email address.",
      "platform": "cloud",
      "hidden": false,
      "defaultTrigger": "type = \"identify\"",
      "fields": [
        {
          "fieldKey": "email",
          "type": "string",
          "label": "Email Address",
          "description": "The prospect's email address.\n        Used to upsert a prospect in Pardot. If multiple prospects have the given email, the prospect with the latest activity is updated. If there's no prospect with the given email, a prospect is created. Please note that Pardot treats email address as case sensitive and will create multiple prospects for casing differences.",
          "defaultValue": {
            "@if": {
              "exists": {
                "@path": "$.traits.email"
              },
              "then": {
                "@path": "$.traits.email"
              },
              "else": {
                "@path": "$.properties.email"
              }
            }
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
