    "scheme": "custom",
    "fields": {
      "app_id": {
        "label": "Workspace ID",
        "description": "Your Moengage Workspace ID.",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": null,
        "default": null,
        "depends_on": null
      },
      "env": {
        "label": "Environment",
        "description": "The environment for your Moengage account.",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": [
          {
            "label": "LIVE",
            "value": "LIVE"
          },
          {
            "label": "TEST",
            "value": "TEST"
          }
        ],
        "default": "LIVE",
        "depends_on": null
      },
      "moeDataCenter": {
        "label": "Datacenter",
        "description": "The datacenter for your Moengage account.",
        "type": "string",
        "required": true,
        "multiple": false,
        "choices": [
          {
            "label": "DC-01",
            "value": "dc_1"
          },
          {
            "label": "DC-02",
            "value": "dc_2"
          },
          {
            "label": "DC-03",
            "value": "dc_3"
          },
          {
            "label": "DC-04",
            "value": "dc_4"
          },
