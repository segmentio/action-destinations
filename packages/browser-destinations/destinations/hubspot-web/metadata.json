            "@path": "$.traits.email"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "email": {
                "title": "Email Address",
                "description": "The contact’s email. Email is used to uniquely identify contact records in HubSpot and create or update the contact accordingly.",
