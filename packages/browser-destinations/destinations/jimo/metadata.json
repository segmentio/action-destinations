  "presets": [
    {
      "partnerAction": "sendGroupData",
      "name": "Send Group Data",
      "subscribe": "type = \"group\"",
      "mapping": {
        "groupId": {
          "@path": "$.groupId"
        },
        "traits": {
          "@path": "$.traits"
        }
      },
      "type": "automatic"
    },
    {
      "partnerAction": "sendTrackEvent",
      "name": "Send Track Event",
      "subscribe": "type = \"track\"",
      "mapping": {
        "messageId": {
          "@path": "$.messageId"
