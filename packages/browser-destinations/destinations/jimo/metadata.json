          "label": "Group ID",
          "description": "The unique identifier for the group",
          "defaultValue": {
            "@path": "$.groupId"
          },
          "required": true,
          "multiple": false,
          "choices": null,
          "dynamic": false,
          "placeholder": "",
          "allowNull": false,
          "fieldSchema": {
            "$schema": "http://json-schema.org/schema#",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "groupId": {
                "title": "Group ID",
                "description": "The unique identifier for the group",
                "type": "string"
              }
