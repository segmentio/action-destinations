      "hidden": false,
      "label": "Segment Loads Userpilot JS",
      "private": false,
      "scope": "event_destination",
      "type": "boolean",
      "readOnly": false,
      "dependsOn": null,
      "validators": [["required", "The shouldSegmentLoadSDK property is required."]],
      "uIMetadata": null
    }
  },
