{
  "name": "Survicate (Actions)",
  "description": "Send user traits to Survicate and trigger surveys with Segment events",
  "basicOptions": [
    "workspaceKey"
  ],
  "options": {
    "workspaceKey": {
      "tags": [],
      "default": "",
      "description": "The workspace key for your Survicate account.",
      "encrypt": false,
      "hidden": false,
      "label": "Workspace Key",
      "private": false,
      "scope": "event_destination",
      "type": "string",
      "readOnly": false,
      "dependsOn": null,
      "validators": [
        [
          "required",
          "The workspaceKey property is required."
        ]
      ],
      "uIMetadata": null
    }
  },
  "platforms": {
    "browser": true,
    "server": false,
    "mobile": false,
    "warehouse": false,
    "cloudAppObject": false
  },
  "supportedRegions": [
    "us-west-2",
    "eu-west-1"
  ],
  "supportsAudiences": false,
  "actions": [
